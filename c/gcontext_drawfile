/*************************************************** Gerph *********
 Function:     gcontext_drawfile_line_add
 Description:  Add a segment to the current line path
 Parameters:   gc-> graphics context
               x0,y0,x1,y1 = segment coordinates
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_line_add(gcontext_t *gc,
                                       gcontext_drawfile_linestyle_t linestyle,
                                       int32_t x0, int32_t y0,
                                       int32_t x1, int32_t y1)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_object_t *object;
    int32_t lastx;
    int32_t lasty;
    int32_t transformed_x0;
    int32_t transformed_y0;
    int32_t transformed_x1;
    int32_t transformed_y1;

    if (gc->clipstate == cs_suppress)
        return;

    if (!gcontext_drawfile_transform_point(gc, x0, y0, &transformed_x0, &transformed_y0) ||
        !gcontext_drawfile_transform_point(gc, x1, y1, &transformed_x1, &transformed_y1))
        return;

    if (!gcontext_drawfile_line_ensure(gc, linestyle))
        return;

    drawfile = gc->backend_private;
    object = drawfile->current_line;
    if (object == NULL)
        return;

    if (!gcontext_drawfile_path_lastxy(object, &lastx, &lasty) ||
        lastx != transformed_x0 ||
        lasty != transformed_y0)
    {
        if (!gcontext_drawfile_path_addpoint(object, DRAWFILE_PATH_MOVE,
                                             transformed_x0, transformed_y0))
        {
            gcontext_drawfile_free_object(object);
            drawfile->current_line = NULL;
            return;
        }
    }

    if (!gcontext_drawfile_path_addpoint(object, DRAWFILE_PATH_LINE,
                                         transformed_x1, transformed_y1))
    {
        gcontext_drawfile_free_object(object);
        drawfile->current_line = NULL;
    }
}

