/*************************************************** Gerph *********
 Function:     gcontext_drawfile_scale_coordinate
 Description:  Scale a coordinate without overflowing the DrawFile range
 Parameters:   coordinate = source coordinate
               scale = positive DrawFile units per OS unit
               result = transformed coordinate
 Returns:      non-zero if the result is representable
 ******************************************************************/
static int gcontext_drawfile_scale_coordinate(int32_t coordinate,
                                              int32_t scale,
                                              int32_t *result)
{
    if ((coordinate > 0 && coordinate > INT32_MAX / scale) ||
        (coordinate < 0 && coordinate < INT32_MIN / scale))
        return 0;

    *result = coordinate * scale;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_transform_coordinate
 Description:  Scale and translate a coordinate into DrawFile units
 Parameters:   gc = graphics context
               coordinate = source coordinate
               xaxis = non-zero for an x coordinate
               result = transformed coordinate
 Returns:      non-zero if the result is representable
 ******************************************************************/
static int gcontext_drawfile_transform_coordinate(gcontext_t *gc,
                                                  int32_t coordinate,
                                                  int xaxis,
                                                  int32_t *result)
{
    gcontext_drawfile_t *drawfile;
    int32_t scale;
    int32_t translation;
    int32_t scaled;

    drawfile = gc->backend_private;
    scale = xaxis ? drawfile->xscale : drawfile->yscale;
    translation = xaxis ? drawfile->xtranslation : drawfile->ytranslation;
    if (!gcontext_drawfile_scale_coordinate(coordinate, scale, &scaled) ||
        (translation > 0 && scaled > INT32_MAX - translation) ||
        (translation < 0 && scaled < INT32_MIN - translation))
        return 0;

    *result = scaled + translation;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_transform_point
 Description:  Transform a point into DrawFile units
 Parameters:   gc = graphics context
               x,y = source point
               transformed_x,transformed_y = transformed point
 Returns:      non-zero if the result is representable
 ******************************************************************/
static int gcontext_drawfile_transform_point(gcontext_t *gc,
                                             int32_t x,
                                             int32_t y,
                                             int32_t *transformed_x,
                                             int32_t *transformed_y)
{
    return gcontext_drawfile_transform_coordinate(gc, x, 1, transformed_x) &&
           gcontext_drawfile_transform_coordinate(gc, y, 0, transformed_y);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_transform_bbox
 Description:  Transform an axis-aligned bounding box into DrawFile units
 Parameters:   gc = graphics context
               bbox = bounding box to transform
 Returns:      non-zero if the result is representable
 ******************************************************************/
static int gcontext_drawfile_transform_bbox(gcontext_t *gc, bbox_t *bbox)
{
    int32_t x0;
    int32_t y0;
    int32_t x1;
    int32_t y1;

    if (!gcontext_drawfile_transform_point(gc, bbox->x0, bbox->y0, &x0, &y0) ||
        !gcontext_drawfile_transform_point(gc, bbox->x1, bbox->y1, &x1, &y1))
        return 0;

    bbox->x0 = x0;
    bbox->y0 = y0;
    bbox->x1 = x1;
    bbox->y1 = y1;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_fontsize
 Description:  Convert a Font Manager size to scaled DrawFile units
 Parameters:   size = font size in points multiplied by 16
               scale = DrawFile units per GContext OS unit
               result = DrawFile font size in scaled points
 Returns:      non-zero if the result is representable
 ******************************************************************/
static int gcontext_drawfile_fontsize(int32_t size,
                                      int32_t scale,
                                      int32_t *result)
{
    int32_t scaled;

    if (size < 0 ||
        !gcontext_drawfile_scale_coordinate(size, scale, &scaled) ||
        scaled > INT32_MAX / 5)
        return 0;

    *result = (scaled * 5) / 32;
    return 1;
}


/*************************************************** Gerph *********
 Function:     gcontext_generic_rectoutline
 Description:  Outline a rectangle through the line primitives
 Parameters:   gc-> graphics context
               colour = line colour
               x0,y0,x1,y1 = rectangle corners
 Returns:      none
 ******************************************************************/
static void gcontext_generic_rectoutline(gcontext_t *gc,
                                         colour_t colour,
                                         int32_t x0, int32_t y0,
                                         int32_t x1, int32_t y1)
{
    gc->line_start(gc, colour);
    gc->line_line(gc, x0, y0, x0, y1);
    gc->line_line(gc, x0, y1, x1, y1);
    gc->line_line(gc, x1, y1, x1, y0);
    gc->line_line(gc, x1, y0, x0, y0);
    gc->line_end(gc);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_colour
 Description:  Convert a GContext colour to a Draw colour
 Parameters:   colour = colour to convert
 Returns:      Draw colour value
 ******************************************************************/
static int32_t gcontext_drawfile_colour(colour_t colour)
{
    if (colour == COLOUR_NONE)
        return DRAWFILE_COLOUR_NONE;
    return (int32_t) colour;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_free_serial
 Description:  Free any cached serialised data
 Parameters:   drawfile-> drawfile state
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_free_serial(gcontext_drawfile_t *drawfile)
{
    free(drawfile->serialised.data);
    drawfile->serialised.data = NULL;
    drawfile->serialised.length = 0;
    drawfile->serialised.capacity = 0;
    drawfile->serialised_valid = 0;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_invalidate
 Description:  Invalidate cached serialised data after a mutation
 Parameters:   drawfile-> drawfile state
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_invalidate(gcontext_drawfile_t *drawfile)
{
    gcontext_drawfile_free_serial(drawfile);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_strdup
 Description:  Duplicate a string
 Parameters:   src = source string
 Returns:      duplicated string or NULL
 ******************************************************************/
static char *gcontext_drawfile_strdup(const char *src)
{
    char *copy;
    size_t length;

    if (src == NULL)
        return NULL;

    length = strlen(src) + 1;
    copy = malloc(length);
    if (copy == NULL)
        return NULL;

    memcpy(copy, src, length);
    return copy;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_bounds_empty
 Description:  Create an empty bounding box sentinel
 Parameters:   none
 Returns:      empty bounding box
 ******************************************************************/
static bbox_t gcontext_drawfile_bounds_empty(void)
{
    bbox_t bbox;

    bbox.x0 = 0x7fffffff;
    bbox.y0 = 0x7fffffff;
    bbox.x1 = -0x7fffffff;
    bbox.y1 = -0x7fffffff;
    return bbox;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_bounds_isempty
 Description:  Check whether a bounding box is empty
 Parameters:   bbox-> bounding box
 Returns:      non-zero if empty
 ******************************************************************/
static int gcontext_drawfile_bounds_isempty(const bbox_t *bbox)
{
    return bbox->x0 > bbox->x1 || bbox->y0 > bbox->y1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_bounds_include
 Description:  Expand a bounding box to include a point
 Parameters:   bbox-> bounding box
               x,y = point to include
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_bounds_include(bbox_t *bbox, int32_t x, int32_t y)
{
    if (x < bbox->x0)
        bbox->x0 = x;
    if (y < bbox->y0)
        bbox->y0 = y;
    if (x > bbox->x1)
        bbox->x1 = x;
    if (y > bbox->y1)
        bbox->y1 = y;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_bounds_extend
 Description:  Expand a bounding box to include another bounding box
 Parameters:   bbox-> destination bounds
               other-> bounds to include
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_bounds_extend(bbox_t *bbox, const bbox_t *other)
{
    if (gcontext_drawfile_bounds_isempty(other))
        return;

    gcontext_drawfile_bounds_include(bbox, other->x0, other->y0);
    gcontext_drawfile_bounds_include(bbox, other->x1, other->y1);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_bounds_intersects
 Description:  Check whether two bounding boxes intersect
 Parameters:   bbox-> first bounding box
               other-> second bounding box
 Returns:      non-zero if they intersect
 ******************************************************************/
static int gcontext_drawfile_bounds_intersects(const bbox_t *bbox,
                                               const bbox_t *other)
{
    if (gcontext_drawfile_bounds_isempty(bbox) ||
        gcontext_drawfile_bounds_isempty(other))
        return 0;

    if (bbox->x1 <= other->x0 || bbox->x0 >= other->x1)
        return 0;
    if (bbox->y1 <= other->y0 || bbox->y0 >= other->y1)
        return 0;

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_clip_accepts
 Description:  Check whether an object should be emitted
 Parameters:   gc-> graphics context
               bbox-> object bounds
 Returns:      non-zero if the object should be kept
 ******************************************************************/
static int gcontext_drawfile_clip_accepts(gcontext_t *gc, const bbox_t *bbox)
{
    if (gc->clipstate == cs_suppress)
        return 0;

    if (gc->clipstate != cs_clip)
        return 1;

    return gcontext_drawfile_bounds_intersects(&gc->clipping, bbox);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_free_object
 Description:  Destroy a drawfile object
 Parameters:   object-> object to destroy
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_free_object(gcontext_drawfile_object_t *object)
{
    if (object == NULL)
        return;

    switch (object->type)
    {
        case gcontext_drawfile_object_path:
            free(object->data.path.dashes);
            free(object->data.path.points);
            break;

        case gcontext_drawfile_object_text:
            free(object->data.text.text);
            break;
    }

    free(object);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_append_object
 Description:  Append an object to the drawfile
 Parameters:   gc-> graphics context
               object-> object to append
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_append_object(gcontext_t *gc,
                                            gcontext_drawfile_object_t *object)
{
    gcontext_drawfile_t *drawfile;

    if (object == NULL)
        return;

    if (!gcontext_drawfile_clip_accepts(gc, &object->bbox))
    {
        gcontext_drawfile_free_object(object);
        return;
    }

    drawfile = gc->backend_private;
    object->next = NULL;
    if (drawfile->tail == NULL)
        drawfile->head = object;
    else
        drawfile->tail->next = object;
    drawfile->tail = object;
    gcontext_drawfile_invalidate(drawfile);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serial_reserve
 Description:  Ensure space in a serial buffer
 Parameters:   serial-> serial buffer
               extra = bytes to add
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serial_reserve(gcontext_drawfile_serial_t *serial,
                                            size_t extra)
{
    unsigned char *newdata;
    size_t wanted;
    size_t capacity;

    wanted = serial->length + extra;
    if (wanted <= serial->capacity)
        return 1;

    capacity = serial->capacity ? serial->capacity : 256;
    while (capacity < wanted)
        capacity <<= 1;

    newdata = realloc(serial->data, capacity);
    if (newdata == NULL)
        return 0;

    serial->data = newdata;
    serial->capacity = capacity;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serial_add
 Description:  Append bytes to a serial buffer
 Parameters:   serial-> serial buffer
               data-> data to append
               length = bytes to append
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serial_add(gcontext_drawfile_serial_t *serial,
                                        const void *data,
                                        size_t length)
{
    if (length == 0)
        return 1;

    if (!gcontext_drawfile_serial_reserve(serial, length))
        return 0;

    memcpy(serial->data + serial->length, data, length);
    serial->length += length;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serial_addword
 Description:  Append a 32-bit word to a serial buffer
 Parameters:   serial-> serial buffer
               value = value to append
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serial_addword(gcontext_drawfile_serial_t *serial,
                                            int32_t value)
{
    return gcontext_drawfile_serial_add(serial, &value, sizeof(value));
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serial_align4
 Description:  Align a serial buffer to a word boundary
 Parameters:   serial-> serial buffer
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serial_align4(gcontext_drawfile_serial_t *serial)
{
    static const int32_t zero = 0;
    size_t pad;

    pad = serial->length & 3;
    if (pad == 0)
        return 1;

    pad = 4 - pad;
    return gcontext_drawfile_serial_add(serial, &zero, pad);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_new_path
 Description:  Create a path object
 Parameters:   fill = fill colour
               line = line colour
               style = drawfile path style bits
 Returns:      object or NULL
 ******************************************************************/
static gcontext_drawfile_object_t *gcontext_drawfile_new_path(colour_t fill,
                                                              colour_t line,
                                                              int32_t style)
{
    gcontext_drawfile_object_t *object;

    object = calloc(1, sizeof(*object));
    if (object == NULL)
        return NULL;

    object->type = gcontext_drawfile_object_path;
    object->bbox = gcontext_drawfile_bounds_empty();
    object->data.path.fill = fill;
    object->data.path.line = line;
    object->data.path.style = style;
    return object;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_path_addpoint
 Description:  Append a point command to a path object
 Parameters:   object-> path object
               type = command type
               x,y = coordinates
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_path_addpoint(gcontext_drawfile_object_t *object,
                                           int32_t type,
                                           int32_t x,
                                           int32_t y)
{
    gcontext_drawfile_path_t *path;
    gcontext_drawfile_point_t *points;
    size_t allocated;

    path = &object->data.path;
    if (path->used == path->allocated)
    {
        allocated = path->allocated ? path->allocated * 2 : 8;
        points = realloc(path->points, allocated * sizeof(*points));
        if (points == NULL)
            return 0;
        path->points = points;
        path->allocated = allocated;
    }

    path->points[path->used].type = type;
    path->points[path->used].x = x;
    path->points[path->used].y = y;
    path->used++;
    gcontext_drawfile_bounds_include(&object->bbox, x, y);
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_path_lastxy
 Description:  Read the final coordinate in a path
 Parameters:   object-> path object
               x = destination for x
               y = destination for y
 Returns:      non-zero if a point was found
 ******************************************************************/
static int gcontext_drawfile_path_lastxy(gcontext_drawfile_object_t *object,
                                         int32_t *x,
                                         int32_t *y)
{
    gcontext_drawfile_path_t *path;
    size_t index;

    path = &object->data.path;
    if (path->used == 0)
        return 0;

    index = path->used - 1;
    *x = path->points[index].x;
    *y = path->points[index].y;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_path_setdash
 Description:  Set the dash pattern for a path
 Parameters:   object-> path object
               dashes-> dash lengths
               dashcount = number of dash entries
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_path_setdash(gcontext_t *gc,
                                          gcontext_drawfile_object_t *object,
                                          const int32_t *dashes,
                                          int32_t dashcount)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_path_t *path;
    int32_t *scaled_dashes;
    int32_t index;

    drawfile = gc->backend_private;
    path = &object->data.path;
    if (dashcount == 0)
        return 1;

    scaled_dashes = malloc(sizeof(*scaled_dashes) * dashcount);
    if (scaled_dashes == NULL)
        return 0;

    for (index = 0; index < dashcount; index++)
    {
        if (!gcontext_drawfile_scale_coordinate(dashes[index], drawfile->xscale,
                                                &scaled_dashes[index]))
        {
            free(scaled_dashes);
            return 0;
        }
    }

    path->dashes = scaled_dashes;
    path->dashcount = dashcount;
    path->style |= (1 << 7);
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_path_finalisebbox
 Description:  Expand a path bounds to include line width
 Parameters:   object-> path object
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_path_finalisebbox(gcontext_drawfile_object_t *object)
{
    int32_t halfwidth;

    halfwidth = object->data.path.linewidth / 2;
    object->bbox.x0 -= halfwidth;
    object->bbox.y0 -= halfwidth;
    object->bbox.x1 += halfwidth;
    object->bbox.y1 += halfwidth;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_text_bbox
 Description:  Build a bounding box from string metrics
 Parameters:   x,y = baseline origin
               bounds-> measured string bounds
 Returns:      text bounding box
 ******************************************************************/
static bbox_t gcontext_drawfile_text_bbox(int32_t x,
                                          int32_t y,
                                          const stringbounds_t *bounds)
{
    bbox_t bbox;

    bbox.x0 = x + bounds->lbearing;
    bbox.y0 = y - bounds->descent;
    bbox.x1 = x + bounds->xoffset + bounds->rbearing;
    bbox.y1 = y + bounds->ascent;
    return bbox;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_findfontrecord
 Description:  Find a stored font record by handle
 Parameters:   drawfile-> drawfile state
               handle = font handle to search for
 Returns:      font record or NULL
 ******************************************************************/
static gcontext_drawfile_font_t *gcontext_drawfile_findfontrecord(gcontext_drawfile_t *drawfile,
                                                                  font_t handle)
{
    gcontext_drawfile_font_t *font;

    font = drawfile->fonts;
    while (font != NULL)
    {
        if (font->handle == handle)
            return font;
        font = font->next;
    }
    return NULL;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_emit_text
 Description:  Emit a text object
 Parameters:   gc-> graphics context
               handle = font handle
               x,y = baseline origin
               bg,fg = colours
               str = string to paint
               strsize = string length
 Returns:      end coordinate
 ******************************************************************/
static coords_t gcontext_drawfile_emit_text(gcontext_t *gc,
                                            font_t handle,
                                            int32_t x,
                                            int32_t y,
                                            colour_t bg,
                                            colour_t fg,
                                            const char *str,
                                            int32_t strsize)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_font_t *font;
    gcontext_drawfile_object_t *object;
    stringbounds_t bounds;
    coords_t end;
    size_t textlength;
    int32_t transformed_x;
    int32_t transformed_y;

    end.x = x;
    end.y = y;

    if (strsize == GCONTEXT_ZEROTERM)
        strsize = strlen(str);
    if (strsize <= 0)
        return end;

    drawfile = gc->backend_private;
    font = gcontext_drawfile_findfontrecord(drawfile, handle);

    gc->text_getstringsize(gc, handle, &bounds, -1, str, strsize, GCONTEXT_NOSPLIT);
    end.x = x + bounds.xoffset;
    end.y = y;

    if (bg != COLOUR_NONE)
    {
        bbox_t bbox;
        bbox = gcontext_drawfile_text_bbox(x, y, &bounds);
        gc->rectangle_fill(gc, bg, bbox.x0, bbox.y0, bbox.x1, bbox.y1);
    }

    object = calloc(1, sizeof(*object));
    if (object == NULL)
        return end;

    textlength = (size_t) strsize + 1;
    object->data.text.text = malloc(textlength);
    if (object->data.text.text == NULL)
    {
        free(object);
        return end;
    }

    memcpy(object->data.text.text, str, (size_t) strsize);
    object->data.text.text[strsize] = '\0';
    object->type = gcontext_drawfile_object_text;
    object->bbox = gcontext_drawfile_text_bbox(x, y, &bounds);
    if (!gcontext_drawfile_transform_bbox(gc, &object->bbox) ||
        !gcontext_drawfile_transform_point(gc, x, y, &transformed_x, &transformed_y))
    {
        gcontext_drawfile_free_object(object);
        return end;
    }
    object->data.text.font = font;
    object->data.text.x = transformed_x;
    object->data.text.y = transformed_y;
    object->data.text.fill = fg;
    gcontext_drawfile_append_object(gc, object);

    return end;
}

