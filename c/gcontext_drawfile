/*************************************************** Gerph *********
 Function:     gcontext_drawfile_line_create
 Description:  Create the current line object with a specific style
 Parameters:   gc-> graphics context
               colour = line colour
               linestyle = solid, dotted or dashed
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_line_create(gcontext_t *gc,
                                         colour_t colour,
                                         gcontext_drawfile_linestyle_t linestyle)
{
    gcontext_drawfile_t *drawfile;

    drawfile = gc->backend_private;
    if (drawfile->current_line != NULL)
        return 1;

    drawfile->current_line = gcontext_drawfile_new_path((colour_t) COLOUR_NONE, colour, 0);
    if (drawfile->current_line == NULL)
        return 0;

    drawfile->current_linestyle = linestyle;
    drawfile->current_linecolour = colour;
    drawfile->current_line->data.path.linewidth = 0;

    if (linestyle == gcontext_drawfile_linestyle_dotted)
    {
        static const int32_t dotted[2] = {
            DRAWFILE_DASH_DOTTED_ON,
            DRAWFILE_DASH_DOTTED_OFF
        };
        if (!gcontext_drawfile_path_setdash(gc, drawfile->current_line, dotted, 2))
        {
            gcontext_drawfile_free_object(drawfile->current_line);
            drawfile->current_line = NULL;
            return 0;
        }
    }
    else if (linestyle == gcontext_drawfile_linestyle_dashed)
    {
        static const int32_t dashed[2] = {
            DRAWFILE_DASH_DASHED_ON,
            DRAWFILE_DASH_DASHED_OFF
        };
        if (!gcontext_drawfile_path_setdash(gc, drawfile->current_line, dashed, 2))
        {
            gcontext_drawfile_free_object(drawfile->current_line);
            drawfile->current_line = NULL;
            return 0;
        }
    }

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_line_ensure
 Description:  Ensure there is a current line object in the requested style
 Parameters:   gc-> graphics context
               linestyle = solid, dotted or dashed
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_line_ensure(gcontext_t *gc,
                                         gcontext_drawfile_linestyle_t linestyle)
{
    gcontext_drawfile_t *drawfile;

    drawfile = gc->backend_private;
    if (drawfile->current_line != NULL &&
        drawfile->current_linestyle != linestyle &&
        drawfile->current_line->data.path.used != 0)
    {
        gcontext_drawfile_line_end(gc);
    }

    drawfile->current_linestyle = linestyle;
    return gcontext_drawfile_line_create(gc, drawfile->current_linecolour, linestyle);
}

