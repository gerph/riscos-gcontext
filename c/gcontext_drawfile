/*************************************************** Gerph *********
 Function:     gcontext_drawfile_paintattrib
 Description:  Emit aligned text and underline if requested
 Parameters:   gc-> graphics context
               handle = font handle
               x0,y0,x1,y1 = enclosing box
               str = string to paint
               strsize = string length
               bg,fg = colours
               attrib = alignment attributes
 Returns:      end coordinate
 ******************************************************************/
static coords_t gcontext_drawfile_paintattrib(gcontext_t *gc,
                                              font_t handle,
                                              int32_t x0, int32_t y0,
                                              int32_t x1, int32_t y1,
                                              const char *str,
                                              int32_t strsize,
                                              colour_t bg,
                                              colour_t fg,
                                              uint32_t attrib)
{
    stringbounds_t bounds;
    int32_t strwidth;
    int32_t strheight;
    int32_t x;
    int32_t y;
    coords_t end;

    end.x = x0;
    end.y = y0;

    gcontext_drawfile_getstringsize(gc, handle, &bounds, -1, str, strsize, GCONTEXT_NOSPLIT);
    strwidth = bounds.lbearing + bounds.rbearing + bounds.xoffset;
    strheight = bounds.ascent + bounds.descent;

    switch (attrib & FONTATTRIB_ALIGN_HMASK)
    {
        default:
        case FONTATTRIB_ALIGN_HLEFT:
retry_left:
            x = x0 + bounds.lbearing;
            break;

        case FONTATTRIB_ALIGN_HRIGHT:
            x = x1 - strwidth + bounds.lbearing;
            break;

        case FONTATTRIB_ALIGN_HCENTRE:
            x = (x0 + x1 - strwidth) / 2 + bounds.lbearing;
            if (x < x0)
                goto retry_left;
            break;
    }
    end.x = x + bounds.xoffset;

    switch (attrib & FONTATTRIB_ALIGN_VMASK)
    {
        default:
        case FONTATTRIB_ALIGN_VTOP:
            y = y1 - strheight + bounds.descent;
            if (y < y0)
                return end;
            end.y = y1;
            break;

        case FONTATTRIB_ALIGN_VBOTTOM:
            y = y0 + bounds.descent;
            if (y + bounds.ascent > y1)
                return end;
            end.y = y0;
            break;

        case FONTATTRIB_ALIGN_VCENTRE:
            y = (y0 + y1 - strheight) / 2 + bounds.descent;
            end.y = y - bounds.descent;
            break;
    }

    if (gc->clipstate != cs_suppress)
    {
        gcontext_drawfile_emit_text(gc, handle, x, y, bg, fg, str, strsize);
        if (attrib & FONTATTRIB_UNDERLINE)
        {
            gc->line_start(gc, fg);
            gc->line_line(gc, x, y, x + bounds.xoffset, y);
            gc->line_end(gc);
        }
    }

    return end;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_clip_rectangle
 Description:  Update the clipping state for drawfile output
 Parameters:   gc-> graphics context
               bbox-> bounding box, or NULL to reset
 Returns:      false, as drawfile clipping is only approximated
 ******************************************************************/
static bool gcontext_drawfile_clip_rectangle(gcontext_t *gc, bbox_t *bbox)
{
    if (bbox == NULL)
    {
        gc->clipstate = cs_noclip;
    }
    else if (bbox->x0 >= bbox->x1 || bbox->y0 >= bbox->y1)
    {
        gc->clipstate = cs_suppress;
        gc->clipping.x0 = 0;
        gc->clipping.y0 = 0;
        gc->clipping.x1 = 1;
        gc->clipping.y1 = 1;
    }
    else
    {
        gc->clipstate = cs_clip;
        gc->clipping = *bbox;
        if (!gcontext_drawfile_transform_bbox(gc, &gc->clipping))
            gc->clipstate = cs_suppress;
    }
    return false;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serialise_fonttable
 Description:  Serialise the DrawFile font table object
 Parameters:   drawfile-> drawfile state
               serial-> serial buffer to append to
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serialise_fonttable(gcontext_drawfile_t *drawfile,
                                                 gcontext_drawfile_serial_t *serial)
{
    gcontext_drawfile_object_t *object;
    gcontext_drawfile_font_t *font;
    gcontext_drawfile_serial_t payload;
    int32_t objectsize;
    int32_t identifier;

    memset(&payload, 0, sizeof(payload));
    identifier = 1;

    object = drawfile->head;
    while (object != NULL)
    {
        if (object->type == gcontext_drawfile_object_text)
        {
            font = object->data.text.font;
            if (font != NULL && font->identifier == 0)
            {
                font->identifier = identifier++;
                if (!gcontext_drawfile_serial_add(&payload, &font->identifier, 1) ||
                    !gcontext_drawfile_serial_add(&payload, font->name, strlen(font->name) + 1))
                {
                    free(payload.data);
                    return 0;
                }
            }
        }
        object = object->next;
    }

    if (payload.length == 0)
    {
        free(payload.data);
        return 1;
    }

    if (!gcontext_drawfile_serial_align4(&payload))
    {
        free(payload.data);
        return 0;
    }

    objectsize = (int32_t) payload.length + 8;
    if (!gcontext_drawfile_serial_addword(serial, DRAWFILE_OBJ_FONTLIST) ||
        !gcontext_drawfile_serial_addword(serial, objectsize) ||
        !gcontext_drawfile_serial_add(serial, payload.data, payload.length))
    {
        free(payload.data);
        return 0;
    }

    free(payload.data);
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serialise_path
 Description:  Serialise a path object into a payload buffer
 Parameters:   object-> path object
               serial-> payload buffer
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serialise_path(const gcontext_drawfile_object_t *object,
                                            gcontext_drawfile_serial_t *serial)
{
    const gcontext_drawfile_path_t *path;
    size_t index;

    path = &object->data.path;
    if (!gcontext_drawfile_serial_addword(serial, gcontext_drawfile_colour(path->fill)) ||
        !gcontext_drawfile_serial_addword(serial, gcontext_drawfile_colour(path->line)) ||
        !gcontext_drawfile_serial_addword(serial, path->linewidth))
        return 0;

    if (!gcontext_drawfile_serial_addword(serial, path->style))
        return 0;

    if (path->dashcount != 0)
    {
        if (!gcontext_drawfile_serial_addword(serial, path->dashoffset) ||
            !gcontext_drawfile_serial_addword(serial, path->dashcount))
            return 0;

        for (index = 0; index < (size_t) path->dashcount; index++)
        {
            if (!gcontext_drawfile_serial_addword(serial, path->dashes[index]))
                return 0;
        }
    }

    for (index = 0; index < path->used; index++)
    {
        if (!gcontext_drawfile_serial_addword(serial, path->points[index].type) ||
            !gcontext_drawfile_serial_addword(serial, path->points[index].x) ||
            !gcontext_drawfile_serial_addword(serial, path->points[index].y))
            return 0;
    }

    if (path->closed)
    {
        if (!gcontext_drawfile_serial_addword(serial, DRAWFILE_PATH_CLOSE))
            return 0;
    }

    return gcontext_drawfile_serial_addword(serial, DRAWFILE_PATH_END);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serialise_text
 Description:  Serialise a text object into a payload buffer
 Parameters:   object-> text object
               serial-> payload buffer
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serialise_text(const gcontext_drawfile_object_t *object,
                                            gcontext_drawfile_serial_t *serial)
{
    const gcontext_drawfile_text_t *text;
    int32_t identifier;

    text = &object->data.text;
    identifier = (text->font == NULL) ? 0 : text->font->identifier;

    if (!gcontext_drawfile_serial_addword(serial, 1 << 16) ||
        !gcontext_drawfile_serial_addword(serial, 0) ||
        !gcontext_drawfile_serial_addword(serial, 0) ||
        !gcontext_drawfile_serial_addword(serial, 1 << 16) ||
        !gcontext_drawfile_serial_addword(serial, 0) ||
        !gcontext_drawfile_serial_addword(serial, 0) ||
        !gcontext_drawfile_serial_addword(serial, 0) ||
        !gcontext_drawfile_serial_addword(serial, gcontext_drawfile_colour(text->fill)) ||
        !gcontext_drawfile_serial_addword(serial, DRAWFILE_COLOUR_NONE) ||
        !gcontext_drawfile_serial_addword(serial, identifier) ||
        !gcontext_drawfile_serial_addword(serial, (text->font == NULL) ? (12 << 4) : text->font->xsize) ||
        !gcontext_drawfile_serial_addword(serial, (text->font == NULL) ? (12 << 4) : text->font->ysize) ||
        !gcontext_drawfile_serial_addword(serial, text->x) ||
        !gcontext_drawfile_serial_addword(serial, text->y) ||
        !gcontext_drawfile_serial_add(serial, text->text, strlen(text->text) + 1) ||
        !gcontext_drawfile_serial_align4(serial))
        return 0;

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_serialise_object
 Description:  Serialise a DrawFile object with its header
 Parameters:   object-> object to serialise
               serial-> destination serial buffer
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_drawfile_serialise_object(const gcontext_drawfile_object_t *object,
                                              gcontext_drawfile_serial_t *serial)
{
    gcontext_drawfile_serial_t payload;
    int32_t tag;
    int32_t size;

    memset(&payload, 0, sizeof(payload));
    switch (object->type)
    {
        case gcontext_drawfile_object_path:
            tag = DRAWFILE_OBJ_PATH;
            if (!gcontext_drawfile_serialise_path(object, &payload))
            {
                free(payload.data);
                return 0;
            }
            break;

        case gcontext_drawfile_object_text:
            tag = DRAWFILE_OBJ_TEXT;
            if (!gcontext_drawfile_serialise_text(object, &payload))
            {
                free(payload.data);
                return 0;
            }
            break;

        default:
            free(payload.data);
            return 0;
    }

    size = (int32_t) payload.length + 24;
    if (!gcontext_drawfile_serial_addword(serial, tag) ||
        !gcontext_drawfile_serial_addword(serial, size) ||
        !gcontext_drawfile_serial_addword(serial, object->bbox.x0) ||
        !gcontext_drawfile_serial_addword(serial, object->bbox.y0) ||
        !gcontext_drawfile_serial_addword(serial, object->bbox.x1) ||
        !gcontext_drawfile_serial_addword(serial, object->bbox.y1) ||
        !gcontext_drawfile_serial_add(serial, payload.data, payload.length))
    {
        free(payload.data);
        return 0;
    }

    free(payload.data);
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_build_serialised
 Description:  Build the serialised DrawFile into the cache
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
static int32_t gcontext_drawfile_build_serialised(gcontext_t *gc)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_object_t *object;
    bbox_t bounds;
    char creator[12];

    drawfile = gc->backend_private;
    if (drawfile->serialised_valid)
        return (int32_t) drawfile->serialised.length;

    gcontext_drawfile_free_serial(drawfile);
    bounds = gcontext_drawfile_bounds_empty();
    object = drawfile->head;
    while (object != NULL)
    {
        gcontext_drawfile_bounds_extend(&bounds, &object->bbox);
        object = object->next;
    }
    if (gcontext_drawfile_bounds_isempty(&bounds))
    {
        bounds.x0 = 0;
        bounds.y0 = 0;
        bounds.x1 = 0;
        bounds.y1 = 0;
    }

    memset(creator, ' ', sizeof(creator));
    memcpy(creator, "GContext", 8);

    object = drawfile->head;
    while (object != NULL)
    {
        if (object->type == gcontext_drawfile_object_text &&
            object->data.text.font != NULL)
            object->data.text.font->identifier = 0;
        object = object->next;
    }

    if (!gcontext_drawfile_serial_addword(&drawfile->serialised, DRAWFILE_MAGIC) ||
        !gcontext_drawfile_serial_addword(&drawfile->serialised, DRAWFILE_MAJOR_VERSION) ||
        !gcontext_drawfile_serial_addword(&drawfile->serialised, DRAWFILE_MINOR_VERSION) ||
        !gcontext_drawfile_serial_add(&drawfile->serialised, creator, sizeof(creator)) ||
        !gcontext_drawfile_serial_addword(&drawfile->serialised, bounds.x0) ||
        !gcontext_drawfile_serial_addword(&drawfile->serialised, bounds.y0) ||
        !gcontext_drawfile_serial_addword(&drawfile->serialised, bounds.x1) ||
        !gcontext_drawfile_serial_addword(&drawfile->serialised, bounds.y1) ||
        !gcontext_drawfile_serialise_fonttable(drawfile, &drawfile->serialised))
    {
        gcontext_drawfile_free_serial(drawfile);
        return -1;
    }

    object = drawfile->head;
    while (object != NULL)
    {
        if (!gcontext_drawfile_serialise_object(object, &drawfile->serialised))
        {
            gcontext_drawfile_free_serial(drawfile);
            return -1;
        }
        object = object->next;
    }

    drawfile->serialised_valid = 1;
    return (int32_t) drawfile->serialised.length;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_backend_finalise
 Description:  Finalise drawfile output to the configured destination
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
static int32_t gcontext_drawfile_backend_finalise(gcontext_t *gc)
{
    gcontext_drawfile_t *drawfile;
    int32_t size;

    drawfile = gc->backend_private;
    size = gcontext_drawfile_build_serialised(gc);
    if (size < 0)
        return -1;

    if (drawfile->target == gcontext_drawfile_target_file)
    {
        FILE *handle;

        handle = fopen(drawfile->filename, "wb");
        if (handle == NULL)
            return -1;

        if (fwrite(drawfile->serialised.data, 1, drawfile->serialised.length, handle) != drawfile->serialised.length)
        {
            fclose(handle);
            remove(drawfile->filename);
            return -1;
        }
        fclose(handle);
        _swix(OS_File, _INR(0,2), 18, drawfile->filename, DRAWFILE_TYPE);
    }
    else
    {
        if ((size_t) size > drawfile->memorysize)
            return -1;
        if (drawfile->memory != NULL && size != 0)
            memcpy(drawfile->memory, drawfile->serialised.data, (size_t) size);
    }

    return size;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_backend_datasize
 Description:  Report the serialised size for the drawfile backend
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
static int32_t gcontext_drawfile_backend_datasize(gcontext_t *gc)
{
    return gcontext_drawfile_build_serialised(gc);
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_backend_destroy
 Description:  Destroy the drawfile backend state
 Parameters:   gc-> graphics context
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_backend_destroy(gcontext_t *gc)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_font_t *font;
    gcontext_drawfile_font_t *nextfont;
    gcontext_drawfile_object_t *object;
    gcontext_drawfile_object_t *nextobject;

    drawfile = gc->backend_private;
    if (drawfile == NULL)
        return;

    if (drawfile->current_line != NULL)
        gcontext_drawfile_free_object(drawfile->current_line);
    if (drawfile->current_fill != NULL)
        gcontext_drawfile_free_object(drawfile->current_fill);

    object = drawfile->head;
    while (object != NULL)
    {
        nextobject = object->next;
        gcontext_drawfile_free_object(object);
        object = nextobject;
    }

    font = drawfile->fonts;
    while (font != NULL)
    {
        nextfont = font->next;
        if (!font->released && font->handle != FONT_NONE)
            fontfallback_losefont(gc, font->handle);
        free(font->name);
        free(font);
        font = nextfont;
    }

    gcontext_drawfile_free_serial(drawfile);
    free(drawfile->filename);
    free(drawfile);
    gc->backend_private = NULL;
}

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfile_common
 Description:  Create a DrawFile-backed graphics context
 Parameters:   target = file or memory destination type
               filename = destination filename for file output
               memory = destination memory for memory output
               memorysize = size of destination memory buffer
               xscale,yscale = positive DrawFile units per OS unit
               xtranslation,ytranslation = DrawFile coordinate offsets
 Returns:      graphics context or NULL
 ******************************************************************/
static gcontext_t *gcontext_initdrawfile_common(gcontext_drawfile_target_t target,
                                                const char *filename,
                                                void *memory,
                                                size_t memorysize,
                                                int32_t xscale,
                                                int32_t yscale,
                                                int32_t xtranslation,
                                                int32_t ytranslation)
{
    gcontext_t *gc;
    gcontext_drawfile_t *drawfile;

    if (xscale <= 0 || yscale <= 0)
        return NULL;

    gc = calloc(1, sizeof(*gc));
    if (gc == NULL)
        return NULL;

    drawfile = calloc(1, sizeof(*drawfile));
    if (drawfile == NULL)
    {
        free(gc);
        return NULL;
    }

    if (filename != NULL)
    {
        drawfile->filename = gcontext_drawfile_strdup(filename);
        if (drawfile->filename == NULL)
        {
            free(drawfile);
            free(gc);
            return NULL;
        }
    }

    drawfile->target = target;
    drawfile->memory = memory;
    drawfile->memorysize = memorysize;
    drawfile->xscale = xscale;
    drawfile->yscale = yscale;
    drawfile->xtranslation = xtranslation;
    drawfile->ytranslation = ytranslation;

    gc->rectangle_fill = gcontext_drawfile_rectangle_fill;
    gc->rectangle_outline = gcontext_generic_rectoutline;
    gc->triangle_fill = gcontext_drawfile_triangle_fill;
    gc->line_start = gcontext_drawfile_line_start;
    gc->line_line = gcontext_drawfile_line_line;
    gc->line_dotted = gcontext_drawfile_line_dotted;
    gc->line_dashed = gcontext_drawfile_line_dashed;
    gc->line_end = gcontext_drawfile_line_end;
    gc->fill_start = gcontext_drawfile_fill_start;
    gc->fill_move = gcontext_drawfile_fill_move;
    gc->fill_line = gcontext_drawfile_fill_line;
    gc->fill_close = gcontext_drawfile_fill_close;
    gc->fill_end = gcontext_drawfile_fill_end;
    gc->text_findfont = gcontext_drawfile_findfont;
    gc->text_losefont = gcontext_drawfile_losefont;
    gc->text_readhandle = gcontext_drawfile_readhandle;
    gc->text_getstringsize = gcontext_drawfile_getstringsize;
    gc->text_getemsize = gcontext_drawfile_getem;
    gc->text_paint = gcontext_drawfile_paint;
    gc->text_paintattrib = gcontext_drawfile_paintattrib;
    gc->clip_rectangle = gcontext_drawfile_clip_rectangle;
    gc->backend_destroy = gcontext_drawfile_backend_destroy;
    gc->backend_finalise = gcontext_drawfile_backend_finalise;
    gc->backend_datasize = gcontext_drawfile_backend_datasize;
    gc->backend_private = drawfile;
    gc->clipstate = cs_noclip;

    return gc;
}

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfile
 Description:  Initialise a DrawFile-backed graphics context for file output
 Parameters:   filename = destination filename
 Returns:      graphics context or NULL
 ******************************************************************/
gcontext_t *gcontext_initdrawfile(const char *filename)
{
    return gcontext_initdrawfile_scaled(filename,
                                        DRAWFILE_OSUNIT,
                                        DRAWFILE_OSUNIT,
                                        0,
                                        0);
}

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfile_scaled
 Description:  Initialise a transformed file-backed DrawFile context
 Parameters:   filename = destination filename
               xscale,yscale = positive DrawFile units per OS unit
               xtranslation,ytranslation = DrawFile coordinate offsets
 Returns:      graphics context or NULL
 ******************************************************************/
gcontext_t *gcontext_initdrawfile_scaled(const char *filename,
                                         int32_t xscale,
                                         int32_t yscale,
                                         int32_t xtranslation,
                                         int32_t ytranslation)
{
    if (filename == NULL)
        return NULL;

    return gcontext_initdrawfile_common(gcontext_drawfile_target_file,
                                        filename,
                                        NULL,
                                        0,
                                        xscale,
                                        yscale,
                                        xtranslation,
                                        ytranslation);
}

