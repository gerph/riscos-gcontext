/*************************************************** Gerph *********
 Function:     gcontext_drawfile_finalise
 Description:  Serialise a DrawFile-backed graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
int32_t gcontext_drawfile_finalise(struct gcontext_s *gc)
{
    if (gc == NULL || gc->backend_finalise == NULL)
        return -1;

    return gc->backend_finalise(gc);
}

