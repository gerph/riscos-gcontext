/*************************************************** Gerph *********
 Function:     gcontext_drawfile_findfont
 Description:  Find a font and remember its metadata
 Parameters:   gc-> graphics context
               name = font name
               xsize,ysize = point sizes * 16
 Returns:      font handle
 ******************************************************************/
static font_t gcontext_drawfile_findfont(gcontext_t *gc,
                                         const char *name,
                                         int32_t xsize,
                                         int32_t ysize)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_font_t *font;
    font_t handle;
    char *fontname;
    int32_t drawfile_xsize;
    int32_t drawfile_ysize;

    drawfile = gc->backend_private;
    handle = fontfallback_findfont(gc, name, xsize, ysize);
    if (gcontext_drawfile_findfontrecord(drawfile, handle) != NULL)
        return handle;

    font = calloc(1, sizeof(*font));
    if (font == NULL)
    {
        fontfallback_losefont(gc, handle);
        return FONT_NONE;
    }

    fontname = gcontext_drawfile_strdup(name ? name : "Trinity.Medium");
    if (fontname == NULL)
    {
        free(font);
        fontfallback_losefont(gc, handle);
        return FONT_NONE;
    }

    if (!gcontext_drawfile_fontsize(xsize, drawfile->xscale, &drawfile_xsize) ||
        !gcontext_drawfile_fontsize(ysize, drawfile->yscale, &drawfile_ysize))
    {
        free(fontname);
        free(font);
        fontfallback_losefont(gc, handle);
        return FONT_NONE;
    }

    font->handle = handle;
    font->name = fontname;
    font->xsize = drawfile_xsize;
    font->ysize = drawfile_ysize;
    font->next = drawfile->fonts;
    drawfile->fonts = font;
    return handle;
}

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_losefont
 Description:  Release a stored font record
 Parameters:   gc-> graphics context
               handle = font handle to release
 Returns:      none
 ******************************************************************/
static void gcontext_drawfile_losefont(gcontext_t *gc, font_t handle)
{
    gcontext_drawfile_t *drawfile;
    gcontext_drawfile_font_t *font;

    drawfile = gc->backend_private;
    font = drawfile->fonts;
    while (font != NULL)
    {
        if (font->handle == handle)
        {
            if (!font->released)
            {
                fontfallback_losefont(gc, handle);
                font->released = 1;
                font->handle = FONT_NONE;
            }
            return;
        }
        font = font->next;
    }

    fontfallback_losefont(gc, handle);
}

