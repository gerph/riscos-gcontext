typedef enum gcontext_svg_target_e
{
    gcontext_svg_target_file,
    gcontext_svg_target_memory
} gcontext_svg_target_t;

typedef enum gcontext_svg_linestyle_e
{
    gcontext_svg_linestyle_solid,
    gcontext_svg_linestyle_dotted,
    gcontext_svg_linestyle_dashed
} gcontext_svg_linestyle_t;

typedef enum gcontext_svg_pointtype_e
{
    gcontext_svg_point_move,
    gcontext_svg_point_line
} gcontext_svg_pointtype_t;

typedef struct gcontext_svg_serial_s
{
    char *data;
    size_t length;
    size_t capacity;
} gcontext_svg_serial_t;

typedef struct gcontext_svg_font_s
{
    struct gcontext_svg_font_s *next;
    font_t handle;
    char *name;
    int32_t xsize;
    int32_t ysize;
    int32_t released;
} gcontext_svg_font_t;

typedef struct gcontext_svg_point_s
{
    gcontext_svg_pointtype_t type;
    int32_t x;
    int32_t y;
} gcontext_svg_point_t;

typedef struct gcontext_svg_path_s
{
    colour_t fill;
    colour_t line;
    int32_t linewidth;
    gcontext_svg_linestyle_t linestyle;
    int32_t closed;
    size_t used;
    size_t allocated;
    gcontext_svg_point_t *points;
} gcontext_svg_path_t;

typedef struct gcontext_svg_text_s
{
    gcontext_svg_font_t *font;
    char *text;
    int32_t x;
    int32_t y;
    colour_t fill;
} gcontext_svg_text_t;

typedef enum gcontext_svg_object_type_e
{
    gcontext_svg_object_path,
    gcontext_svg_object_text
} gcontext_svg_object_type_t;

typedef struct gcontext_svg_object_s
{
    struct gcontext_svg_object_s *next;
    gcontext_svg_object_type_t type;
    bbox_t bbox;
    int32_t clipped;
    bbox_t clip;
    union
    {
        gcontext_svg_path_t path;
        gcontext_svg_text_t text;
    } data;
} gcontext_svg_object_t;

typedef struct gcontext_svg_s
{
    gcontext_svg_target_t target;
    char *filename;
    void *memory;
    size_t memorysize;

    gcontext_svg_font_t *fonts;
    gcontext_svg_object_t *head;
    gcontext_svg_object_t *tail;

    gcontext_svg_object_t *current_line;
    gcontext_svg_linestyle_t current_linestyle;
    colour_t current_linecolour;

    gcontext_svg_object_t *current_fill;
    colour_t current_fillcolour;

    gcontext_svg_serial_t serialised;
    int32_t serialised_valid;
} gcontext_svg_t;

static void gcontext_svg_line_end(gcontext_t *gc);


/*************************************************** Gerph *********
 Function:     gcontext_svg_rectoutline
 Description:  Outline a rectangle through the line primitives
 Parameters:   gc-> graphics context
               colour = line colour
               x0,y0,x1,y1 = rectangle corners
 Returns:      none
 ******************************************************************/
static void gcontext_svg_rectoutline(gcontext_t *gc,
                                     colour_t colour,
                                     int32_t x0, int32_t y0,
                                     int32_t x1, int32_t y1)
{
    gc->line_start(gc, colour);
    gc->line_line(gc, x0, y0, x0, y1);
    gc->line_line(gc, x0, y1, x1, y1);
    gc->line_line(gc, x1, y1, x1, y0);
    gc->line_line(gc, x1, y0, x0, y0);
    gc->line_end(gc);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_free_serial
 Description:  Free any cached serialised data
 Parameters:   svg-> svg state
 Returns:      none
 ******************************************************************/
static void gcontext_svg_free_serial(gcontext_svg_t *svg)
{
    free(svg->serialised.data);
    svg->serialised.data = NULL;
    svg->serialised.length = 0;
    svg->serialised.capacity = 0;
    svg->serialised_valid = 0;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_invalidate
 Description:  Invalidate cached serialised data after a mutation
 Parameters:   svg-> svg state
 Returns:      none
 ******************************************************************/
static void gcontext_svg_invalidate(gcontext_svg_t *svg)
{
    gcontext_svg_free_serial(svg);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_strdup
 Description:  Duplicate a string
 Parameters:   src = source string
 Returns:      duplicated string or NULL
 ******************************************************************/
static char *gcontext_svg_strdup(const char *src)
{
    char *copy;
    size_t length;

    if (src == NULL)
        return NULL;

    length = strlen(src) + 1;
    copy = malloc(length);
    if (copy == NULL)
        return NULL;

    memcpy(copy, src, length);
    return copy;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_empty
 Description:  Create an empty bounding box sentinel
 Parameters:   none
 Returns:      empty bounding box
 ******************************************************************/
static bbox_t gcontext_svg_bounds_empty(void)
{
    bbox_t bbox;

    bbox.x0 = 0x7fffffff;
    bbox.y0 = 0x7fffffff;
    bbox.x1 = -0x7fffffff;
    bbox.y1 = -0x7fffffff;
    return bbox;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_isempty
 Description:  Check whether a bounding box is empty
 Parameters:   bbox-> bounding box
 Returns:      non-zero if empty
 ******************************************************************/
static int gcontext_svg_bounds_isempty(const bbox_t *bbox)
{
    return bbox->x0 > bbox->x1 || bbox->y0 > bbox->y1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_include
 Description:  Expand a bounding box to include a point
 Parameters:   bbox-> bounding box
               x,y = point to include
 Returns:      none
 ******************************************************************/
static void gcontext_svg_bounds_include(bbox_t *bbox, int32_t x, int32_t y)
{
    if (x < bbox->x0)
        bbox->x0 = x;
    if (y < bbox->y0)
        bbox->y0 = y;
    if (x > bbox->x1)
        bbox->x1 = x;
    if (y > bbox->y1)
        bbox->y1 = y;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_extend
 Description:  Expand a bounding box to include another bounding box
 Parameters:   bbox-> destination bounds
               other-> bounds to include
 Returns:      none
 ******************************************************************/
static void gcontext_svg_bounds_extend(bbox_t *bbox, const bbox_t *other)
{
    if (gcontext_svg_bounds_isempty(other))
        return;

    gcontext_svg_bounds_include(bbox, other->x0, other->y0);
    gcontext_svg_bounds_include(bbox, other->x1, other->y1);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_intersects
 Description:  Check whether two bounding boxes intersect
 Parameters:   bbox-> first bounding box
               other-> second bounding box
 Returns:      non-zero if they intersect
 ******************************************************************/
static int gcontext_svg_bounds_intersects(const bbox_t *bbox,
                                          const bbox_t *other)
{
    if (gcontext_svg_bounds_isempty(bbox) ||
        gcontext_svg_bounds_isempty(other))
        return 0;

    if (bbox->x1 <= other->x0 || bbox->x0 >= other->x1)
        return 0;
    if (bbox->y1 <= other->y0 || bbox->y0 >= other->y1)
        return 0;

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_contains
 Description:  Check whether a bounding box wholly contains another
 Parameters:   bbox-> containing bounding box
               other-> bounding box to test
 Returns:      non-zero if other is wholly within bbox
 ******************************************************************/
static int gcontext_svg_bounds_contains(const bbox_t *bbox,
                                        const bbox_t *other)
{
    return other->x0 >= bbox->x0 && other->y0 >= bbox->y0 &&
           other->x1 <= bbox->x1 && other->y1 <= bbox->y1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_bounds_equal
 Description:  Check whether two bounding boxes are identical
 Parameters:   bbox-> first bounding box
               other-> second bounding box
 Returns:      non-zero if identical
 ******************************************************************/
static int gcontext_svg_bounds_equal(const bbox_t *bbox, const bbox_t *other)
{
    return bbox->x0 == other->x0 && bbox->y0 == other->y0 &&
           bbox->x1 == other->x1 && bbox->y1 == other->y1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_clip_accepts
 Description:  Check whether an object should be emitted
 Parameters:   gc-> graphics context
               bbox-> object bounds
 Returns:      non-zero if the object should be kept
 ******************************************************************/
static int gcontext_svg_clip_accepts(gcontext_t *gc, const bbox_t *bbox)
{
    if (gc->clipstate == cs_suppress)
        return 0;

    if (gc->clipstate != cs_clip)
        return 1;

    return gcontext_svg_bounds_intersects(&gc->clipping, bbox);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_free_object
 Description:  Destroy an svg object
 Parameters:   object-> object to destroy
 Returns:      none
 ******************************************************************/
static void gcontext_svg_free_object(gcontext_svg_object_t *object)
{
    if (object == NULL)
        return;

    switch (object->type)
    {
        case gcontext_svg_object_path:
            free(object->data.path.points);
            break;

        case gcontext_svg_object_text:
            free(object->data.text.text);
            break;
    }

    free(object);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_append_object
 Description:  Append an object to the svg document
 Parameters:   gc-> graphics context
               object-> object to append
 Returns:      none
 ******************************************************************/
static void gcontext_svg_append_object(gcontext_t *gc,
                                       gcontext_svg_object_t *object)
{
    gcontext_svg_t *svg;

    if (object == NULL)
        return;

    if (!gcontext_svg_clip_accepts(gc, &object->bbox))
    {
        gcontext_svg_free_object(object);
        return;
    }

    if (gc->clipstate == cs_clip)
    {
        object->clipped = 1;
        object->clip = gc->clipping;
    }

    svg = gc->backend_private;
    object->next = NULL;
    if (svg->tail == NULL)
        svg->head = object;
    else
        svg->tail->next = object;
    svg->tail = object;
    gcontext_svg_invalidate(svg);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serial_reserve
 Description:  Ensure space in a serial buffer
 Parameters:   serial-> serial buffer
               extra = bytes to add
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serial_reserve(gcontext_svg_serial_t *serial,
                                       size_t extra)
{
    char *newdata;
    size_t wanted;
    size_t capacity;

    wanted = serial->length + extra + 1;
    if (wanted <= serial->capacity)
        return 1;

    capacity = serial->capacity ? serial->capacity : 256;
    while (capacity < wanted)
        capacity <<= 1;

    newdata = realloc(serial->data, capacity);
    if (newdata == NULL)
        return 0;

    serial->data = newdata;
    serial->capacity = capacity;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serial_add
 Description:  Append bytes to a serial buffer
 Parameters:   serial-> serial buffer
               data-> data to append
               length = bytes to append
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serial_add(gcontext_svg_serial_t *serial,
                                   const char *data,
                                   size_t length)
{
    if (length == 0)
        return 1;

    if (!gcontext_svg_serial_reserve(serial, length))
        return 0;

    memcpy(serial->data + serial->length, data, length);
    serial->length += length;
    serial->data[serial->length] = '\0';
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serial_addstr
 Description:  Append a NUL-terminated string to a serial buffer
 Parameters:   serial-> serial buffer
               str = string to append
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serial_addstr(gcontext_svg_serial_t *serial,
                                      const char *str)
{
    return gcontext_svg_serial_add(serial, str, strlen(str));
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serial_addint
 Description:  Append a decimal integer to a serial buffer
 Parameters:   serial-> serial buffer
               value = value to append
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serial_addint(gcontext_svg_serial_t *serial,
                                      int32_t value)
{
    char buf[16];

    sprintf(buf, "%ld", (long) value);
    return gcontext_svg_serial_addstr(serial, buf);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serial_addescaped
 Description:  Append XML-escaped text to a serial buffer
 Parameters:   serial-> serial buffer
               str = text to escape and append
               length = number of characters to process
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serial_addescaped(gcontext_svg_serial_t *serial,
                                          const char *str,
                                          size_t length)
{
    size_t index;
    const char *entity;

    for (index = 0; index < length; index++)
    {
        char ch;

        ch = str[index];
        switch (ch)
        {
            case '&':  entity = "&amp;"; break;
            case '<':  entity = "&lt;"; break;
            case '>':  entity = "&gt;"; break;
            case '"':  entity = "&quot;"; break;
            case '\'': entity = "&apos;"; break;
            default:   entity = NULL; break;
        }

        if (entity != NULL)
        {
            if (!gcontext_svg_serial_addstr(serial, entity))
                return 0;
        }
        else
        {
            if (!gcontext_svg_serial_add(serial, &ch, 1))
                return 0;
        }
    }

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_colour_hex
 Description:  Convert a GContext colour to an SVG colour string
 Parameters:   colour = colour to convert
               buf-> destination buffer, at least 8 bytes
 Returns:      none
 ******************************************************************/
static void gcontext_svg_colour_hex(colour_t colour, char *buf)
{
    unsigned long value;
    unsigned long red, green, blue;

    if (colour == COLOUR_NONE)
    {
        strcpy(buf, "none");
        return;
    }

    value = (unsigned long) colour;
    red = (value >> 8) & 0xFFul;
    green = (value >> 16) & 0xFFul;
    blue = (value >> 24) & 0xFFul;
    sprintf(buf, "#%02lx%02lx%02lx", red, green, blue);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_new_path
 Description:  Create a path object
 Parameters:   fill = fill colour
               line = line colour
               linestyle = solid, dotted or dashed
 Returns:      object or NULL
 ******************************************************************/
static gcontext_svg_object_t *gcontext_svg_new_path(colour_t fill,
                                                     colour_t line,
                                                     gcontext_svg_linestyle_t linestyle)
{
    gcontext_svg_object_t *object;

    object = calloc(1, sizeof(*object));
    if (object == NULL)
        return NULL;

    object->type = gcontext_svg_object_path;
    object->bbox = gcontext_svg_bounds_empty();
    object->data.path.fill = fill;
    object->data.path.line = line;
    object->data.path.linestyle = linestyle;
    return object;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_path_addpoint
 Description:  Append a point command to a path object
 Parameters:   object-> path object
               type = move or line
               x,y = coordinates
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_path_addpoint(gcontext_svg_object_t *object,
                                      gcontext_svg_pointtype_t type,
                                      int32_t x,
                                      int32_t y)
{
    gcontext_svg_path_t *path;
    gcontext_svg_point_t *points;
    size_t allocated;

    path = &object->data.path;
    if (path->used == path->allocated)
    {
        allocated = path->allocated ? path->allocated * 2 : 8;
        points = realloc(path->points, allocated * sizeof(*points));
        if (points == NULL)
            return 0;
        path->points = points;
        path->allocated = allocated;
    }

    path->points[path->used].type = type;
    path->points[path->used].x = x;
    path->points[path->used].y = y;
    path->used++;
    gcontext_svg_bounds_include(&object->bbox, x, y);
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_path_lastxy
 Description:  Read the final coordinate in a path
 Parameters:   object-> path object
               x = destination for x
               y = destination for y
 Returns:      non-zero if a point was found
 ******************************************************************/
static int gcontext_svg_path_lastxy(gcontext_svg_object_t *object,
                                    int32_t *x,
                                    int32_t *y)
{
    gcontext_svg_path_t *path;
    size_t index;

    path = &object->data.path;
    if (path->used == 0)
        return 0;

    index = path->used - 1;
    *x = path->points[index].x;
    *y = path->points[index].y;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_path_finalisebbox
 Description:  Expand a path bounds to include line width
 Parameters:   object-> path object
 Returns:      none
 ******************************************************************/
static void gcontext_svg_path_finalisebbox(gcontext_svg_object_t *object)
{
    int32_t halfwidth;

    halfwidth = object->data.path.linewidth / 2;
    object->bbox.x0 -= halfwidth;
    object->bbox.y0 -= halfwidth;
    object->bbox.x1 += halfwidth;
    object->bbox.y1 += halfwidth;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_text_bbox
 Description:  Build a bounding box from string metrics
 Parameters:   x,y = baseline origin
               bounds-> measured string bounds
 Returns:      text bounding box
 ******************************************************************/
static bbox_t gcontext_svg_text_bbox(int32_t x,
                                     int32_t y,
                                     const stringbounds_t *bounds)
{
    bbox_t bbox;

    bbox.x0 = x + bounds->lbearing;
    bbox.y0 = y - bounds->descent;
    bbox.x1 = x + bounds->xoffset + bounds->rbearing;
    bbox.y1 = y + bounds->ascent;
    return bbox;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_findfontrecord
 Description:  Find a stored font record by handle
 Parameters:   svg-> svg state
               handle = font handle to search for
 Returns:      font record or NULL
 ******************************************************************/
static gcontext_svg_font_t *gcontext_svg_findfontrecord(gcontext_svg_t *svg,
                                                         font_t handle)
{
    gcontext_svg_font_t *font;

    font = svg->fonts;
    while (font != NULL)
    {
        if (font->handle == handle)
            return font;
        font = font->next;
    }
    return NULL;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_emit_text
 Description:  Emit a text object
 Parameters:   gc-> graphics context
               handle = font handle
               x,y = baseline origin
               bg,fg = colours
               str = string to paint
               strsize = string length
 Returns:      end coordinate
 ******************************************************************/
static coords_t gcontext_svg_emit_text(gcontext_t *gc,
                                       font_t handle,
                                       int32_t x,
                                       int32_t y,
                                       colour_t bg,
                                       colour_t fg,
                                       const char *str,
                                       int32_t strsize)
{
    gcontext_svg_t *svg;
    gcontext_svg_font_t *font;
    gcontext_svg_object_t *object;
    stringbounds_t bounds;
    coords_t end;
    size_t textlength;

    end.x = x;
    end.y = y;

    if (strsize == GCONTEXT_ZEROTERM)
        strsize = strlen(str);
    if (strsize <= 0)
        return end;

    svg = gc->backend_private;
    font = gcontext_svg_findfontrecord(svg, handle);

    gc->text_getstringsize(gc, handle, &bounds, -1, str, strsize, GCONTEXT_NOSPLIT);
    end.x = x + bounds.xoffset;
    end.y = y;

    if (bg != COLOUR_NONE)
    {
        bbox_t bbox;
        bbox = gcontext_svg_text_bbox(x, y, &bounds);
        gc->rectangle_fill(gc, bg, bbox.x0, bbox.y0, bbox.x1, bbox.y1);
    }

    object = calloc(1, sizeof(*object));
    if (object == NULL)
        return end;

    textlength = (size_t) strsize + 1;
    object->data.text.text = malloc(textlength);
    if (object->data.text.text == NULL)
    {
        free(object);
        return end;
    }

    memcpy(object->data.text.text, str, (size_t) strsize);
    object->data.text.text[strsize] = '\0';
    object->type = gcontext_svg_object_text;
    object->bbox = gcontext_svg_text_bbox(x, y, &bounds);
    object->data.text.font = font;
    object->data.text.x = x;
    object->data.text.y = y;
    object->data.text.fill = fg;
    gcontext_svg_append_object(gc, object);

    return end;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_rectangle_fill
 Description:  Emit a filled rectangle
 Parameters:   gc-> graphics context
               colour = fill colour
               x0,y0,x1,y1 = rectangle corners
 Returns:      none
 ******************************************************************/
static void gcontext_svg_rectangle_fill(gcontext_t *gc,
                                        colour_t colour,
                                        int32_t x0, int32_t y0,
                                        int32_t x1, int32_t y1)
{
    gcontext_svg_object_t *object;

    if (gc->clipstate == cs_suppress)
        return;

    object = gcontext_svg_new_path(colour, (colour_t) COLOUR_NONE, gcontext_svg_linestyle_solid);
    if (object == NULL)
        return;

    if (!gcontext_svg_path_addpoint(object, gcontext_svg_point_move, x0, y0) ||
        !gcontext_svg_path_addpoint(object, gcontext_svg_point_line, x0, y1) ||
        !gcontext_svg_path_addpoint(object, gcontext_svg_point_line, x1, y1) ||
        !gcontext_svg_path_addpoint(object, gcontext_svg_point_line, x1, y0))
    {
        gcontext_svg_free_object(object);
        return;
    }

    object->data.path.closed = 1;
    gcontext_svg_append_object(gc, object);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_triangle_fill
 Description:  Emit a filled triangle
 Parameters:   gc-> graphics context
               colour = fill colour
               x0,y0,x1,y1,x2,y2 = triangle points
 Returns:      none
 ******************************************************************/
static void gcontext_svg_triangle_fill(gcontext_t *gc,
                                       colour_t colour,
                                       int32_t x0, int32_t y0,
                                       int32_t x1, int32_t y1,
                                       int32_t x2, int32_t y2)
{
    gcontext_svg_object_t *object;

    if (gc->clipstate == cs_suppress)
        return;

    object = gcontext_svg_new_path(colour, (colour_t) COLOUR_NONE, gcontext_svg_linestyle_solid);
    if (object == NULL)
        return;

    if (!gcontext_svg_path_addpoint(object, gcontext_svg_point_move, x0, y0) ||
        !gcontext_svg_path_addpoint(object, gcontext_svg_point_line, x1, y1) ||
        !gcontext_svg_path_addpoint(object, gcontext_svg_point_line, x2, y2))
    {
        gcontext_svg_free_object(object);
        return;
    }

    object->data.path.closed = 1;
    gcontext_svg_append_object(gc, object);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_line_create
 Description:  Create the current line object with a specific style
 Parameters:   gc-> graphics context
               colour = line colour
               linestyle = solid, dotted or dashed
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_line_create(gcontext_t *gc,
                                    colour_t colour,
                                    gcontext_svg_linestyle_t linestyle)
{
    gcontext_svg_t *svg;

    svg = gc->backend_private;
    if (svg->current_line != NULL)
        return 1;

    svg->current_line = gcontext_svg_new_path((colour_t) COLOUR_NONE, colour, linestyle);
    if (svg->current_line == NULL)
        return 0;

    svg->current_linestyle = linestyle;
    svg->current_linecolour = colour;
    svg->current_line->data.path.linewidth = 0;

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_line_ensure
 Description:  Ensure there is a current line object in the requested style
 Parameters:   gc-> graphics context
               linestyle = solid, dotted or dashed
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_line_ensure(gcontext_t *gc,
                                    gcontext_svg_linestyle_t linestyle)
{
    gcontext_svg_t *svg;

    svg = gc->backend_private;
    if (svg->current_line != NULL &&
        svg->current_linestyle != linestyle &&
        svg->current_line->data.path.used != 0)
    {
        gcontext_svg_line_end(gc);
    }

    svg->current_linestyle = linestyle;
    return gcontext_svg_line_create(gc, svg->current_linecolour, linestyle);
}

