    svg->current_linestyle = gcontext_svg_linestyle_solid;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_line_add
 Description:  Add a segment to the current line path
 Parameters:   gc-> graphics context
               linestyle = solid, dotted or dashed
               x0,y0,x1,y1 = segment coordinates
 Returns:      none
 ******************************************************************/
static void gcontext_svg_line_add(gcontext_t *gc,
                                  gcontext_svg_linestyle_t linestyle,
                                  int32_t x0, int32_t y0,
                                  int32_t x1, int32_t y1)
{
    gcontext_svg_t *svg;
    gcontext_svg_object_t *object;
    int32_t lastx;
    int32_t lasty;

    if (gc->clipstate == cs_suppress)
        return;

    if (!gcontext_svg_line_ensure(gc, linestyle))
        return;

    svg = gc->backend_private;
    object = svg->current_line;
    if (object == NULL)
        return;

    if (!gcontext_svg_path_lastxy(object, &lastx, &lasty) ||
        lastx != x0 ||
        lasty != y0)
    {
        if (!gcontext_svg_path_addpoint(object, gcontext_svg_point_move, x0, y0))
        {
            gcontext_svg_free_object(object);
            svg->current_line = NULL;
            return;
        }
    }

    if (!gcontext_svg_path_addpoint(object, gcontext_svg_point_line, x1, y1))
    {
        gcontext_svg_free_object(object);
        svg->current_line = NULL;
    }
}

