/*************************************************** Gerph *********
 Function:     gcontext_svg_findfont
 Description:  Find a font and remember its metadata
 Parameters:   gc-> graphics context
               name = font name
               xsize,ysize = point sizes * 16
 Returns:      font handle
 ******************************************************************/
static font_t gcontext_svg_findfont(gcontext_t *gc,
                                    const char *name,
                                    int32_t xsize,
                                    int32_t ysize)
{
    gcontext_svg_t *svg;
    gcontext_svg_font_t *font;
    font_t handle;
    char *fontname;

    svg = gc->backend_private;
    handle = fontfallback_findfont(gc, name, xsize, ysize);
    if (gcontext_svg_findfontrecord(svg, handle) != NULL)
        return handle;

    font = calloc(1, sizeof(*font));
    if (font == NULL)
    {
        fontfallback_losefont(gc, handle);
        return FONT_NONE;
    }

    fontname = gcontext_svg_strdup(name ? name : "Trinity.Medium");
    if (fontname == NULL)
    {
        free(font);
        fontfallback_losefont(gc, handle);
        return FONT_NONE;
    }

    font->handle = handle;
    font->name = fontname;
    font->xsize = xsize;
    font->ysize = ysize;
    font->next = svg->fonts;
    svg->fonts = font;
    return handle;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_losefont
 Description:  Release a stored font record
 Parameters:   gc-> graphics context
               handle = font handle to release
 Returns:      none
 ******************************************************************/
static void gcontext_svg_losefont(gcontext_t *gc, font_t handle)
{
    gcontext_svg_t *svg;
    gcontext_svg_font_t *font;

    svg = gc->backend_private;
    font = svg->fonts;
    while (font != NULL)
    {
        if (font->handle == handle)
        {
            if (!font->released)
            {
                fontfallback_losefont(gc, handle);
                font->released = 1;
                font->handle = FONT_NONE;
            }
            return;
        }
        font = font->next;
    }

    fontfallback_losefont(gc, handle);
}

