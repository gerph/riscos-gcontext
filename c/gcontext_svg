/*************************************************** Gerph *********
 Function:     gcontext_svg_paintattrib
 Description:  Emit aligned text and underline if requested
 Parameters:   gc-> graphics context
               handle = font handle
               x0,y0,x1,y1 = enclosing box
               str = string to paint
               strsize = string length
               bg,fg = colours
               attrib = alignment attributes
 Returns:      end coordinate
 ******************************************************************/
static coords_t gcontext_svg_paintattrib(gcontext_t *gc,
                                         font_t handle,
                                         int32_t x0, int32_t y0,
                                         int32_t x1, int32_t y1,
                                         const char *str,
                                         int32_t strsize,
                                         colour_t bg,
                                         colour_t fg,
                                         uint32_t attrib)
{
    stringbounds_t bounds;
    int32_t strwidth;
    int32_t strheight;
    int32_t x;
    int32_t y;
    coords_t end;

    end.x = x0;
    end.y = y0;

    gcontext_svg_getstringsize(gc, handle, &bounds, -1, str, strsize, GCONTEXT_NOSPLIT);
    strwidth = bounds.lbearing + bounds.rbearing + bounds.xoffset;
    strheight = bounds.ascent + bounds.descent;

    switch (attrib & FONTATTRIB_ALIGN_HMASK)
    {
        default:
        case FONTATTRIB_ALIGN_HLEFT:
retry_left:
            x = x0 + bounds.lbearing;
            break;

        case FONTATTRIB_ALIGN_HRIGHT:
            x = x1 - strwidth + bounds.lbearing;
            break;

        case FONTATTRIB_ALIGN_HCENTRE:
            x = (x0 + x1 - strwidth) / 2 + bounds.lbearing;
            if (x < x0)
                goto retry_left;
            break;
    }
    end.x = x + bounds.xoffset;

    switch (attrib & FONTATTRIB_ALIGN_VMASK)
    {
        default:
        case FONTATTRIB_ALIGN_VTOP:
            y = y1 - strheight + bounds.descent;
            if (y < y0)
                return end;
            end.y = y1;
            break;

        case FONTATTRIB_ALIGN_VBOTTOM:
            y = y0 + bounds.descent;
            if (y + bounds.ascent > y1)
                return end;
            end.y = y0;
            break;

        case FONTATTRIB_ALIGN_VCENTRE:
            y = (y0 + y1 - strheight) / 2 + bounds.descent;
            end.y = y - bounds.descent;
            break;
    }

    if (gc->clipstate != cs_suppress)
    {
        gcontext_svg_emit_text(gc, handle, x, y, bg, fg, str, strsize);
        if (attrib & FONTATTRIB_UNDERLINE)
        {
            gc->line_start(gc, fg);
            gc->line_line(gc, x, y, x + bounds.xoffset, y);
            gc->line_end(gc);
        }
    }

    return end;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_clip_rectangle
 Description:  Update the clipping state for svg output
 Parameters:   gc-> graphics context
               bbox-> bounding box, or NULL to reset
 Returns:      true, as svg clip regions are fully enforced
 ******************************************************************/
static bool gcontext_svg_clip_rectangle(gcontext_t *gc, bbox_t *bbox)
{
    if (bbox == NULL)
    {
        gc->clipstate = cs_noclip;
    }
    else if (bbox->x0 >= bbox->x1 || bbox->y0 >= bbox->y1)
    {
        gc->clipstate = cs_suppress;
        gc->clipping.x0 = 0;
        gc->clipping.y0 = 0;
        gc->clipping.x1 = 1;
        gc->clipping.y1 = 1;
    }
    else
    {
        gc->clipstate = cs_clip;
        gc->clipping = *bbox;
    }
    return true;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_fontfamily
 Description:  Map a RISC OS font name to CSS font attributes
 Parameters:   name = RISC OS font name, or NULL for the system font
               family-> destination buffer for font-family
               bold-> destination for bold flag
               italic-> destination for italic flag
 Returns:      none
 ******************************************************************/
static void gcontext_svg_fontfamily(const char *name,
                                    const char **family,
                                    int *bold,
                                    int *italic)
{
    *family = "sans-serif";
    *bold = 0;
    *italic = 0;

    if (name == NULL)
        return;

    if (strncmp(name, "Trinity", 7) == 0)
        *family = "serif";
    else if (strncmp(name, "Homerton", 8) == 0)
        *family = "sans-serif";
    else if (strncmp(name, "Corpus", 6) == 0)
        *family = "monospace";

    if (strstr(name, "Bold") != NULL)
        *bold = 1;
    if (strstr(name, "Italic") != NULL || strstr(name, "Oblique") != NULL)
        *italic = 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serialise_clipdefs
 Description:  Serialise the <clipPath> definitions used by objects
 Parameters:   svg-> svg state
               serial-> destination serial buffer
               clips-> destination array of unique clip rectangles
               clipcount-> destination for number of unique clips
               fx0,fy1 = flip origin (docbounds.x0, docbounds.y1)
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serialise_clipdefs(gcontext_svg_t *svg,
                                           gcontext_svg_serial_t *serial,
                                           bbox_t **clips,
                                           size_t *clipcount,
                                           int32_t fx0,
                                           int32_t fy1)
{
    gcontext_svg_object_t *object;
    bbox_t *found;
    size_t allocated;
    size_t count;
    size_t index;

    found = NULL;
    allocated = 0;
    count = 0;

    object = svg->head;
    while (object != NULL)
    {
        if (object->clipped)
        {
            int seen;

            seen = 0;
            for (index = 0; index < count; index++)
            {
                if (gcontext_svg_bounds_equal(&found[index], &object->clip))
                {
                    seen = 1;
                    break;
                }
            }

            if (!seen)
            {
                if (count == allocated)
                {
                    bbox_t *newfound;

                    allocated = allocated ? allocated * 2 : 4;
                    newfound = realloc(found, allocated * sizeof(*found));
                    if (newfound == NULL)
                    {
                        free(found);
                        return 0;
                    }
                    found = newfound;
                }
                found[count] = object->clip;
                count++;
            }
        }
        object = object->next;
    }

    if (count != 0)
    {
        if (!gcontext_svg_serial_addstr(serial, "  <defs>\n"))
        {
            free(found);
            return 0;
        }

        for (index = 0; index < count; index++)
        {
            int32_t sx0, sy0, sx1, sy1;

            sx0 = found[index].x0 - fx0;
            sx1 = found[index].x1 - fx0;
            sy0 = fy1 - found[index].y1;
            sy1 = fy1 - found[index].y0;

            if (!gcontext_svg_serial_addstr(serial, "    <clipPath id=\"clip") ||
                !gcontext_svg_serial_addint(serial, (int32_t) index) ||
                !gcontext_svg_serial_addstr(serial, "\"><rect x=\"") ||
                !gcontext_svg_serial_addint(serial, sx0) ||
                !gcontext_svg_serial_addstr(serial, "\" y=\"") ||
                !gcontext_svg_serial_addint(serial, sy0) ||
                !gcontext_svg_serial_addstr(serial, "\" width=\"") ||
                !gcontext_svg_serial_addint(serial, sx1 - sx0) ||
                !gcontext_svg_serial_addstr(serial, "\" height=\"") ||
                !gcontext_svg_serial_addint(serial, sy1 - sy0) ||
                !gcontext_svg_serial_addstr(serial, "\"/></clipPath>\n"))
            {
                free(found);
                return 0;
            }
        }

        if (!gcontext_svg_serial_addstr(serial, "  </defs>\n"))
        {
            free(found);
            return 0;
        }
    }

    *clips = found;
    *clipcount = count;
    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serialise_clipattr
 Description:  Emit a clip-path attribute for an object, if required
 Parameters:   object-> object being serialised
               serial-> destination serial buffer
               clips-> unique clip rectangle array
               clipcount = number of unique clips
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serialise_clipattr(const gcontext_svg_object_t *object,
                                           gcontext_svg_serial_t *serial,
                                           const bbox_t *clips,
                                           size_t clipcount)
{
    size_t index;

    if (!object->clipped)
        return 1;

    if (gcontext_svg_bounds_contains(&object->clip, &object->bbox))
        return 1;

    for (index = 0; index < clipcount; index++)
    {
        if (gcontext_svg_bounds_equal(&clips[index], &object->clip))
        {
            return gcontext_svg_serial_addstr(serial, " clip-path=\"url(#clip") &&
                   gcontext_svg_serial_addint(serial, (int32_t) index) &&
                   gcontext_svg_serial_addstr(serial, ")\"");
        }
    }

    return 1;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serialise_path
 Description:  Serialise a path object as an SVG <path> element
 Parameters:   object-> path object
               serial-> destination serial buffer
               fx0,fy1 = flip origin (docbounds.x0, docbounds.y1)
               clips-> unique clip rectangle array
               clipcount = number of unique clips
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serialise_path(const gcontext_svg_object_t *object,
                                       gcontext_svg_serial_t *serial,
                                       int32_t fx0,
                                       int32_t fy1,
                                       const bbox_t *clips,
                                       size_t clipcount)
{
    const gcontext_svg_path_t *path;
    char colourbuf[8];
    size_t index;

    path = &object->data.path;

    if (!gcontext_svg_serial_addstr(serial, "  <path d=\""))
        return 0;

    for (index = 0; index < path->used; index++)
    {
        int32_t sx, sy;

        sx = path->points[index].x - fx0;
        sy = fy1 - path->points[index].y;

        if (!gcontext_svg_serial_addstr(serial, path->points[index].type == gcontext_svg_point_move ? "M" : "L") ||
            !gcontext_svg_serial_addint(serial, sx) ||
            !gcontext_svg_serial_addstr(serial, ",") ||
            !gcontext_svg_serial_addint(serial, sy) ||
            !gcontext_svg_serial_addstr(serial, " "))
            return 0;
    }

    if (path->closed)
    {
        if (!gcontext_svg_serial_addstr(serial, "Z"))
            return 0;
    }

    if (!gcontext_svg_serial_addstr(serial, "\" fill=\""))
        return 0;
    gcontext_svg_colour_hex(path->fill, colourbuf);
    if (!gcontext_svg_serial_addstr(serial, colourbuf) ||
        !gcontext_svg_serial_addstr(serial, "\" stroke=\""))
        return 0;
    gcontext_svg_colour_hex(path->line, colourbuf);
    if (!gcontext_svg_serial_addstr(serial, colourbuf) ||
        !gcontext_svg_serial_addstr(serial, "\""))
        return 0;

    if (path->line != (colour_t) COLOUR_NONE)
    {
        if (!gcontext_svg_serial_addstr(serial, " stroke-linecap=\"round\" stroke-linejoin=\"round\""))
            return 0;

        if (path->linestyle == gcontext_svg_linestyle_dotted)
        {
            if (!gcontext_svg_serial_addstr(serial, " stroke-dasharray=\"") ||
                !gcontext_svg_serial_addint(serial, SVG_DASH_DOTTED_ON) ||
                !gcontext_svg_serial_addstr(serial, ",") ||
                !gcontext_svg_serial_addint(serial, SVG_DASH_DOTTED_OFF) ||
                !gcontext_svg_serial_addstr(serial, "\""))
                return 0;
        }
        else if (path->linestyle == gcontext_svg_linestyle_dashed)
        {
            if (!gcontext_svg_serial_addstr(serial, " stroke-dasharray=\"") ||
                !gcontext_svg_serial_addint(serial, SVG_DASH_DASHED_ON) ||
                !gcontext_svg_serial_addstr(serial, ",") ||
                !gcontext_svg_serial_addint(serial, SVG_DASH_DASHED_OFF) ||
                !gcontext_svg_serial_addstr(serial, "\""))
                return 0;
        }
    }

    if (!gcontext_svg_serialise_clipattr(object, serial, clips, clipcount))
        return 0;

    return gcontext_svg_serial_addstr(serial, "/>\n");
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_serialise_text
 Description:  Serialise a text object as an SVG <text> element
 Parameters:   object-> text object
               serial-> destination serial buffer
               fx0,fy1 = flip origin (docbounds.x0, docbounds.y1)
               clips-> unique clip rectangle array
               clipcount = number of unique clips
 Returns:      non-zero if successful
 ******************************************************************/
static int gcontext_svg_serialise_text(const gcontext_svg_object_t *object,
                                       gcontext_svg_serial_t *serial,
                                       int32_t fx0,
                                       int32_t fy1,
                                       const bbox_t *clips,
                                       size_t clipcount)
{
    const gcontext_svg_text_t *text;
    const char *family;
    int32_t fontsize;
    int bold;
    int italic;
    char colourbuf[8];
    int32_t sx, sy;

    text = &object->data.text;
    fontsize = (object->bbox.y1 - object->bbox.y0);
    if (fontsize <= 0)
        fontsize = 1;

    gcontext_svg_fontfamily(text->font != NULL ? text->font->name : NULL, &family, &bold, &italic);

    sx = text->x - fx0;
    sy = fy1 - text->y;

    if (!gcontext_svg_serial_addstr(serial, "  <text x=\"") ||
        !gcontext_svg_serial_addint(serial, sx) ||
        !gcontext_svg_serial_addstr(serial, "\" y=\"") ||
        !gcontext_svg_serial_addint(serial, sy) ||
        !gcontext_svg_serial_addstr(serial, "\" font-family=\"") ||
        !gcontext_svg_serial_addstr(serial, family) ||
        !gcontext_svg_serial_addstr(serial, "\" font-size=\"") ||
        !gcontext_svg_serial_addint(serial, fontsize) ||
        !gcontext_svg_serial_addstr(serial, "\""))
        return 0;

    if (bold)
    {
        if (!gcontext_svg_serial_addstr(serial, " font-weight=\"bold\""))
            return 0;
    }
    if (italic)
    {
        if (!gcontext_svg_serial_addstr(serial, " font-style=\"italic\""))
            return 0;
    }

    if (!gcontext_svg_serial_addstr(serial, " fill=\""))
        return 0;
    gcontext_svg_colour_hex(text->fill, colourbuf);
    if (!gcontext_svg_serial_addstr(serial, colourbuf) ||
        !gcontext_svg_serial_addstr(serial, "\""))
        return 0;

    if (!gcontext_svg_serialise_clipattr(object, serial, clips, clipcount))
        return 0;

    if (!gcontext_svg_serial_addstr(serial, ">"))
        return 0;

    if (!gcontext_svg_serial_addescaped(serial, text->text, strlen(text->text)))
        return 0;

    return gcontext_svg_serial_addstr(serial, "</text>\n");
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_build_serialised
 Description:  Build the serialised SVG document into the cache
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
static int32_t gcontext_svg_build_serialised(gcontext_t *gc)
{
    gcontext_svg_t *svg;
    gcontext_svg_object_t *object;
    bbox_t bounds;
    bbox_t *clips;
    size_t clipcount;
    int32_t width;
    int32_t height;

    svg = gc->backend_private;
    if (svg->serialised_valid)
        return (int32_t) svg->serialised.length;

    gcontext_svg_free_serial(svg);
    bounds = gcontext_svg_bounds_empty();
    object = svg->head;
    while (object != NULL)
    {
        gcontext_svg_bounds_extend(&bounds, &object->bbox);
        object = object->next;
    }
    if (gcontext_svg_bounds_isempty(&bounds))
    {
        bounds.x0 = 0;
        bounds.y0 = 0;
        bounds.x1 = 0;
        bounds.y1 = 0;
    }

    width = bounds.x1 - bounds.x0;
    height = bounds.y1 - bounds.y0;

    if (!gcontext_svg_serial_addstr(&svg->serialised, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n") ||
        !gcontext_svg_serial_addstr(&svg->serialised, "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"") ||
        !gcontext_svg_serial_addint(&svg->serialised, width) ||
        !gcontext_svg_serial_addstr(&svg->serialised, "\" height=\"") ||
        !gcontext_svg_serial_addint(&svg->serialised, height) ||
        !gcontext_svg_serial_addstr(&svg->serialised, "\" viewBox=\"0 0 ") ||
        !gcontext_svg_serial_addint(&svg->serialised, width) ||
        !gcontext_svg_serial_addstr(&svg->serialised, " ") ||
        !gcontext_svg_serial_addint(&svg->serialised, height) ||
        !gcontext_svg_serial_addstr(&svg->serialised, "\">\n"))
    {
        gcontext_svg_free_serial(svg);
        return -1;
    }

    clips = NULL;
    clipcount = 0;
    if (!gcontext_svg_serialise_clipdefs(svg, &svg->serialised, &clips, &clipcount, bounds.x0, bounds.y1))
    {
        gcontext_svg_free_serial(svg);
        return -1;
    }

    object = svg->head;
    while (object != NULL)
    {
        int ok;

        if (object->type == gcontext_svg_object_path)
            ok = gcontext_svg_serialise_path(object, &svg->serialised, bounds.x0, bounds.y1, clips, clipcount);
        else
            ok = gcontext_svg_serialise_text(object, &svg->serialised, bounds.x0, bounds.y1, clips, clipcount);

        if (!ok)
        {
            free(clips);
            gcontext_svg_free_serial(svg);
            return -1;
        }
        object = object->next;
    }

    free(clips);

    if (!gcontext_svg_serial_addstr(&svg->serialised, "</svg>\n"))
    {
        gcontext_svg_free_serial(svg);
        return -1;
    }

    svg->serialised_valid = 1;
    return (int32_t) svg->serialised.length;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_backend_finalise
 Description:  Finalise SVG output to the configured destination
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
static int32_t gcontext_svg_backend_finalise(gcontext_t *gc)
{
    gcontext_svg_t *svg;
    int32_t size;

    svg = gc->backend_private;
    size = gcontext_svg_build_serialised(gc);
    if (size < 0)
        return -1;

    if (svg->target == gcontext_svg_target_file)
    {
        FILE *handle;

        handle = fopen(svg->filename, "wb");
        if (handle == NULL)
            return -1;

        if (fwrite(svg->serialised.data, 1, svg->serialised.length, handle) != svg->serialised.length)
        {
            fclose(handle);
            remove(svg->filename);
            return -1;
        }
        fclose(handle);
        _swix(OS_File, _INR(0,2), 18, svg->filename, SVG_FILETYPE);
    }
    else
    {
        if ((size_t) size > svg->memorysize)
            return -1;
        if (svg->memory != NULL && size != 0)
            memcpy(svg->memory, svg->serialised.data, (size_t) size);
    }

    return size;
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_backend_datasize
 Description:  Report the serialised size for the svg backend
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
static int32_t gcontext_svg_backend_datasize(gcontext_t *gc)
{
    return gcontext_svg_build_serialised(gc);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_backend_destroy
 Description:  Destroy the svg backend state
 Parameters:   gc-> graphics context
 Returns:      none
 ******************************************************************/
static void gcontext_svg_backend_destroy(gcontext_t *gc)
{
    gcontext_svg_t *svg;
    gcontext_svg_font_t *font;
    gcontext_svg_font_t *nextfont;
    gcontext_svg_object_t *object;
    gcontext_svg_object_t *nextobject;

    svg = gc->backend_private;
    if (svg == NULL)
        return;

    if (svg->current_line != NULL)
        gcontext_svg_free_object(svg->current_line);
    if (svg->current_fill != NULL)
        gcontext_svg_free_object(svg->current_fill);

    object = svg->head;
    while (object != NULL)
    {
        nextobject = object->next;
        gcontext_svg_free_object(object);
        object = nextobject;
    }

    font = svg->fonts;
    while (font != NULL)
    {
        nextfont = font->next;
        if (!font->released && font->handle != FONT_NONE)
            fontfallback_losefont(gc, font->handle);
        free(font->name);
        free(font);
        font = nextfont;
    }

    gcontext_svg_free_serial(svg);
    free(svg->filename);
    free(svg);
    gc->backend_private = NULL;
}

/*************************************************** Gerph *********
 Function:     gcontext_initsvg_common
 Description:  Create an SVG-backed graphics context
 Parameters:   target = file or memory destination type
               filename = destination filename for file output
               memory = destination memory for memory output
               memorysize = size of destination memory buffer
 Returns:      graphics context or NULL
 ******************************************************************/
static gcontext_t *gcontext_initsvg_common(gcontext_svg_target_t target,
                                           const char *filename,
                                           void *memory,
                                           size_t memorysize)
{
    gcontext_t *gc;
    gcontext_svg_t *svg;

    gc = calloc(1, sizeof(*gc));
    if (gc == NULL)
        return NULL;

    svg = calloc(1, sizeof(*svg));
    if (svg == NULL)
    {
        free(gc);
        return NULL;
    }

    if (filename != NULL)
    {
        svg->filename = gcontext_svg_strdup(filename);
        if (svg->filename == NULL)
        {
            free(svg);
            free(gc);
            return NULL;
        }
    }

    svg->target = target;
    svg->memory = memory;
    svg->memorysize = memorysize;

    gc->rectangle_fill = gcontext_svg_rectangle_fill;
    gc->rectangle_outline = gcontext_svg_rectoutline;
    gc->triangle_fill = gcontext_svg_triangle_fill;
    gc->line_start = gcontext_svg_line_start;
    gc->line_line = gcontext_svg_line_line;
    gc->line_dotted = gcontext_svg_line_dotted;
    gc->line_dashed = gcontext_svg_line_dashed;
    gc->line_end = gcontext_svg_line_end;
    gc->fill_start = gcontext_svg_fill_start;
    gc->fill_move = gcontext_svg_fill_move;
    gc->fill_line = gcontext_svg_fill_line;
    gc->fill_close = gcontext_svg_fill_close;
    gc->fill_end = gcontext_svg_fill_end;
    gc->text_findfont = gcontext_svg_findfont;
    gc->text_losefont = gcontext_svg_losefont;
    gc->text_readhandle = gcontext_svg_readhandle;
    gc->text_getstringsize = gcontext_svg_getstringsize;
    gc->text_getemsize = gcontext_svg_getem;
    gc->text_paint = gcontext_svg_paint;
    gc->text_paintattrib = gcontext_svg_paintattrib;
    gc->clip_rectangle = gcontext_svg_clip_rectangle;
    gc->backend_destroy = gcontext_svg_backend_destroy;
    gc->backend_finalise = gcontext_svg_backend_finalise;
    gc->backend_datasize = gcontext_svg_backend_datasize;
    gc->backend_private = svg;
    gc->clipstate = cs_noclip;

    return gc;
}

/*************************************************** Gerph *********
 Function:     gcontext_initsvg
 Description:  Initialise an SVG-backed graphics context for file output
 Parameters:   filename = destination filename
 Returns:      graphics context or NULL
 ******************************************************************/
gcontext_t *gcontext_initsvg(const char *filename)
{
    if (filename == NULL)
        return NULL;

    return gcontext_initsvg_common(gcontext_svg_target_file,
                                   filename,
                                   NULL,
                                   0);
}

/*************************************************** Gerph *********
 Function:     gcontext_initsvgmemory
 Description:  Initialise an SVG-backed graphics context for memory output
 Parameters:   memory = destination memory, or NULL to size only
               memorysize = size of destination memory
 Returns:      graphics context or NULL
 ******************************************************************/
gcontext_t *gcontext_initsvgmemory(void *memory, size_t memorysize)
{
    return gcontext_initsvg_common(gcontext_svg_target_memory,
                                   NULL,
                                   memory,
                                   memorysize);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_finalise
 Description:  Serialise an SVG-backed graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
int32_t gcontext_svg_finalise(struct gcontext_s *gc)
{
    if (gc == NULL || gc->backend_finalise == NULL)
        return -1;

    return gc->backend_finalise(gc);
}

/*************************************************** Gerph *********
 Function:     gcontext_svg_datasize
 Description:  Report the size of the SVG data for a graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if unavailable
 ******************************************************************/
int32_t gcontext_svg_datasize(struct gcontext_s *gc)
{
    if (gc == NULL || gc->backend_datasize == NULL)
        return -1;

    return gc->backend_datasize(gc);
}
