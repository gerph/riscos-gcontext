#ifndef GCONTEXT_H
#define GCONTEXT_H

#include <stdbool.h>
#include <stddef.h>
#include <stdint.h>

#define FONTATTRIB_ALIGN_HLEFT   (0<<0)
#define FONTATTRIB_ALIGN_HCENTRE (1<<0)
#define FONTATTRIB_ALIGN_HRIGHT  (2<<0)
#define FONTATTRIB_ALIGN_HMASK   (3<<0)
#define FONTATTRIB_ALIGN_VTOP    (0<<2)
#define FONTATTRIB_ALIGN_VCENTRE (1<<2)
#define FONTATTRIB_ALIGN_VBOTTOM (2<<2)
#define FONTATTRIB_ALIGN_VMASK   (3<<2)
#define FONTATTRIB_UNDERLINE     (1<<4)

#define COLOUR_NONE (0xFFFFFFFFlu)
#define COLOUR_RGB(r,g,b) ((((uint32_t)(r))<<8) | (((uint32_t)(g))<<16) | (((uint32_t)(b))<<24))

typedef uint32_t colour_t;

typedef struct coords_s {
    int32_t x;
    int32_t y;
} coords_t;

typedef struct bounds_s {
    int32_t width;
    int32_t height;
} bounds_t;

typedef struct bbox_s {
    int32_t x0, y0;
    int32_t x1, y1;
} bbox_t;

typedef struct stringbounds_s {
    int32_t ascent, descent; /* How far characters go above the baseline, and below */
    int32_t lbearing, rbearing; /* How far characters go to the left of the origin, and to the right of the xoffset */
    int32_t xoffset; /* How far along the baseline the next character position is */
    int32_t charoffset; /* The character offset of the split character */
} stringbounds_t;

typedef struct font_s *font_t;

/* When no font can be returned */
#define FONT_NONE ((font_t)(NULL))

/* No split character to be used */
#define GCONTEXT_NOSPLIT  (-1)

/* Length is the string length terminated by 0 */
#define GCONTEXT_ZEROTERM (-1)

/* Number of DrawFile coordinate units in one RISC OS OS unit. */
#define DRAWFILE_OSUNIT   256

/* Backend-specific public entry points are declared in this header. */

typedef struct gcontext_s {
    void (*rectangle_fill)(struct gcontext_s *gc,
                           colour_t colour,
                           int x0, int y0, int x1, int y1);
    void (*rectangle_outline)(struct gcontext_s *gc,
                              colour_t colour,
                              int32_t x0, int32_t y0, int32_t x1, int32_t y1);

    void (*triangle_fill)(struct gcontext_s *gc,
                          colour_t colour,
                          int32_t x0, int32_t y0, int32_t x1, int32_t y1, int32_t x2, int32_t y2);

    void (*line_start)(struct gcontext_s *gc,
                       colour_t colour);
    void (*line_line)(struct gcontext_s *gc,
                      int32_t x0, int32_t y0, int32_t x1, int32_t y1);
    void (*line_dotted)(struct gcontext_s *gc,
                        int32_t x0, int32_t y0, int32_t x1, int32_t y1);
    void (*line_dashed)(struct gcontext_s *gc,
                        int32_t x0, int32_t y0, int32_t x1, int32_t y1);
    void (*line_end)(struct gcontext_s *gc);

    void (*fill_start)(struct gcontext_s *gc,
                       colour_t fill_colour); /* Note: Will be NULL if not supported */
    void (*fill_move)(struct gcontext_s *gc,
                      int32_t x, int32_t y);
    void (*fill_line)(struct gcontext_s *gc,
                      int32_t x, int32_t y);
    void (*fill_close)(struct gcontext_s *gc);
    void (*fill_end)(struct gcontext_s *gc);

    font_t (*text_findfont)(struct gcontext_s *gc,
                            const char *name, int xsize, int ysize);
    void (*text_losefont)(struct gcontext_s *gc,
                          font_t handle);
    uint32_t (*text_readhandle)(struct gcontext_s *gc, font_t font);

    void (*text_getstringsize)(struct gcontext_s *gc,
                               font_t, stringbounds_t *bounds,
                               int32_t xlimit,
                               const char *str, int strsize, int split_char);

    bounds_t (*text_getemsize)(struct gcontext_s *gc,
                               font_t);

    coords_t (*text_paint)(struct gcontext_s *gc,
                           font_t handle,
                           int32_t xb, int32_t yb,
                           colour_t bg, colour_t fg,
                           const char *str, int strsize);

    coords_t (*text_paintattrib)(struct gcontext_s *gc,
                                 font_t handle,
                                 int32_t x, int32_t y, int32_t x1, int32_t y1,
                                 const char *str, int strsize,
                                 colour_t bg, colour_t fg,
                                 uint32_t attrib);

    bool (*clip_rectangle)(struct gcontext_s *gc,
                           bbox_t *bbox);

    void (*backend_destroy)(struct gcontext_s *gc);
    int32_t (*backend_finalise)(struct gcontext_s *gc);
    int32_t (*backend_datasize)(struct gcontext_s *gc);

    /* Private information */
    bbox_t clipping;
    enum clipstate_e {
        cs_noclip,      /* No clipping enforced; everything drawn */
        cs_suppress,    /* Completely clipped; nothing drawn */
        cs_clip         /* Clipping by the clipping box */
    } clipstate;

    void *backend_private;
} gcontext_t;


/*************************************************** Gerph *********
 Function:     gcontext_initvdu
 Description:  Initialise the graphics context for the VDU system
 Parameters:   fonts = 1 if we should use fonts
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initvdu(int fonts);

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfile
 Description:  Initialise a graphics context which serialises to a DrawFile
 Parameters:   filename = filename to create on finalisation; coordinates use
               DRAWFILE_OSUNIT DrawFile units per GContext OS unit
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initdrawfile(const char *filename);

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfile_scaled
 Description:  Initialise a transformed DrawFile graphics context
 Parameters:   filename = filename to create on finalisation
               xscale,yscale = DrawFile units per GContext OS unit
               xtranslation,ytranslation = DrawFile coordinate offsets
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initdrawfile_scaled(const char *filename,
                                                int32_t xscale,
                                                int32_t yscale,
                                                int32_t xtranslation,
                                                int32_t ytranslation);

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfilememory
 Description:  Initialise a graphics context which serialises to memory
 Parameters:   memory = destination buffer, or NULL to size only
               memorysize = size of the destination buffer
               coordinates use DRAWFILE_OSUNIT DrawFile units per GContext OS unit
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initdrawfilememory(void *memory, size_t memorysize);

/*************************************************** Gerph *********
 Function:     gcontext_initdrawfilememory_scaled
 Description:  Initialise a transformed memory-backed DrawFile context
 Parameters:   memory = destination buffer, or NULL to size only
               memorysize = size of the destination buffer
               xscale,yscale = DrawFile units per GContext OS unit
               xtranslation,ytranslation = DrawFile coordinate offsets
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initdrawfilememory_scaled(void *memory,
                                                      size_t memorysize,
                                                      int32_t xscale,
                                                      int32_t yscale,
                                                      int32_t xtranslation,
                                                      int32_t ytranslation);

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_finalise
 Description:  Serialise a DrawFile-backed graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
int32_t gcontext_drawfile_finalise(struct gcontext_s *gc);

/*************************************************** Gerph *********
 Function:     gcontext_drawfile_datasize
 Description:  Report the size of the DrawFile data for a graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if unavailable
 ******************************************************************/
int32_t gcontext_drawfile_datasize(struct gcontext_s *gc);

/*************************************************** Gerph *********
 Function:     gcontext_initsvg
 Description:  Initialise a graphics context which serialises to an SVG file
 Parameters:   filename = filename to create on finalisation
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initsvg(const char *filename);

/*************************************************** Gerph *********
 Function:     gcontext_initsvgmemory
 Description:  Initialise a graphics context which serialises SVG to memory
 Parameters:   memory = destination buffer, or NULL to size only
               memorysize = size of the destination buffer
 Returns:      gcontext_t to use for plotting, or NULL if unavailable
 ******************************************************************/
struct gcontext_s *gcontext_initsvgmemory(void *memory, size_t memorysize);

/*************************************************** Gerph *********
 Function:     gcontext_svg_finalise
 Description:  Serialise an SVG-backed graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if failed
 ******************************************************************/
int32_t gcontext_svg_finalise(struct gcontext_s *gc);

/*************************************************** Gerph *********
 Function:     gcontext_svg_datasize
 Description:  Report the size of the SVG data for a graphics context
 Parameters:   gc-> graphics context
 Returns:      size of serialised data, or -1 if unavailable
 ******************************************************************/
int32_t gcontext_svg_datasize(struct gcontext_s *gc);

/*************************************************** Gerph *********
 Function:     gcontext_destroy
 Description:  Release a graphics context and any backend state
 Parameters:   gc-> graphics context
 Returns:      none
 ******************************************************************/
void gcontext_destroy(struct gcontext_s *gc);

#endif
